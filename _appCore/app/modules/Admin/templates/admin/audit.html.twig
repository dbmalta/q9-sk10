{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.audit_log') }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <h1 class="h3 mb-4">{{ t('nav.audit_log') }}</h1>

    <div class="card">
        <table class="table mb-0 small">
            <thead>
                <tr>
                    <th>{{ t('audit.when') }}</th>
                    <th>{{ t('audit.user') }}</th>
                    <th>{{ t('audit.action') }}</th>
                    <th>{{ t('audit.entity') }}</th>
                </tr>
            </thead>
            <tbody>
            {% for row in entries %}
                <tr>
                    <td class="text-nowrap">{{ row.created_at }}</td>
                    <td>{{ row.user_email|default('system') }}</td>
                    <td><span class="badge bg-secondary">{{ row.action }}</span></td>
                    <td>{{ row.entity_type }}#{{ row.entity_id|default('—') }}</td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-center text-muted py-3">{{ t('common.none') }}</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
