{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.backups') }}{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">{{ t('nav.backups') }}</h1>
        <form method="post" action="{{ route('admin.backups.create') }}">
            {{ csrf_field()|raw }}
            <button class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>{{ t('backups.create') }}</button>
        </form>
    </div>

    <div class="card">
        <table class="table mb-0">
            <thead><tr><th>{{ t('backups.filename') }}</th><th>{{ t('backups.size') }}</th><th>{{ t('backups.created') }}</th><th></th></tr></thead>
            <tbody>
            {% for b in backups %}
                <tr>
                    <td><code>{{ b.filename }}</code></td>
                    <td>{{ (b.size / 1024)|number_format(1) }} KB</td>
                    <td>{{ b.created_at }}</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" href="{{ route('admin.backups.download', {filename: b.filename}) }}">
                            <i class="bi bi-download"></i>
                        </a>
                        <form method="post" action="{{ route('admin.backups.delete', {filename: b.filename}) }}" class="d-inline">
                            {{ csrf_field()|raw }}
                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('{{ t('common.confirm_delete') }}')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-center text-muted py-3">{{ t('common.none') }}</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
