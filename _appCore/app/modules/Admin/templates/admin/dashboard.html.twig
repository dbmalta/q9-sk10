{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.dashboard') }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <h1 class="h3 mb-4">{{ t('nav.dashboard') }}</h1>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted small">{{ t('dashboard.users') }}</div>
                    <div class="display-6 fw-semibold">{{ stats.user_count }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">{{ t('dashboard.system') }}</div>
                    <dl class="row mb-0 mt-2 small">
                        <dt class="col-sm-3">{{ t('dashboard.php_version') }}</dt><dd class="col-sm-9">{{ health.php_version }}</dd>
                        <dt class="col-sm-3">{{ t('dashboard.app_version') }}</dt><dd class="col-sm-9">{{ health.app_version }}</dd>
                        <dt class="col-sm-3">{{ t('dashboard.db_size') }}</dt><dd class="col-sm-9">{{ health.db_size }}</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">{{ t('dashboard.recent_logins') }}</div>
                <ul class="list-group list-group-flush">
                    {% for row in stats.recent_logins %}
                        <li class="list-group-item d-flex justify-content-between">
                            <span>{{ row.email }}</span>
                            <span class="text-muted small">{{ row.last_login_at }}</span>
                        </li>
                    {% else %}
                        <li class="list-group-item text-muted small">{{ t('common.none') }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">{{ t('dashboard.recent_audit') }}</div>
                <ul class="list-group list-group-flush">
                    {% for row in stats.recent_audit %}
                        <li class="list-group-item small">
                            <span class="fw-semibold">{{ row.action }}</span>
                            <span class="text-muted">on</span>
                            {{ row.entity_type }}#{{ row.entity_id|default('—') }}
                            <span class="text-muted">by</span> {{ row.email|default('system') }}
                            <span class="text-muted float-end">{{ row.created_at }}</span>
                        </li>
                    {% else %}
                        <li class="list-group-item text-muted small">{{ t('common.none') }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}
