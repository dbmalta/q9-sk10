{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.logs') }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <h1 class="h3 mb-3">{{ t('nav.logs') }}</h1>

    <ul class="nav nav-pills mb-3">
        {% for t in types %}
            <li class="nav-item">
                <a class="nav-link {{ t == type ? 'active' : '' }}"
                   href="{{ route('admin.logs') }}?type={{ t }}">{{ t }}</a>
            </li>
        {% endfor %}
    </ul>

    <div class="d-flex justify-content-end mb-2">
        <form method="post" action="{{ route('admin.logs.clear', {type: type}) }}">
            {{ csrf_field()|raw }}
            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('{{ t('common.confirm') }}')">
                <i class="bi bi-trash me-1"></i>{{ t('logs.clear') }}
            </button>
        </form>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <pre class="m-0 p-3 small" style="max-height: 70vh; overflow: auto;">{% for entry in entries %}{{ entry|json_encode }}
{% endfor %}{% if entries is empty %}{{ t('common.none') }}{% endif %}</pre>
        </div>
    </div>
</div>
{% endblock %}
