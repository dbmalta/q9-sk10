{% extends "layouts/admin.html.twig" %}

{% set isEdit = notice is not null %}

{% block title %}
    {{ isEdit ? t('notices.edit') : t('notices.create') }}
{% endblock %}

{% block content %}
<div class="container py-4" style="max-width: 800px;">
    <h1 class="h3 mb-4">{{ isEdit ? t('notices.edit') : t('notices.create') }}</h1>

    <form method="post" action="{{ isEdit ? route('admin.notices.update', {id: notice.id}) : route('admin.notices.store') }}">
        {{ csrf_field()|raw }}

        <div class="mb-3">
            <label class="form-label" for="title">{{ t('notices.title') }}</label>
            <input type="text" class="form-control" id="title" name="title"
                   value="{{ notice.title|default('') }}" required>
        </div>

        <div class="mb-3">
            <label class="form-label" for="type">{{ t('notices.type') }}</label>
            <select name="type" id="type" class="form-select">
                <option value="informational" {% if notice and notice.type == 'informational' %}selected{% endif %}>{{ t('notices.informational') }}</option>
                <option value="must_acknowledge" {% if notice and notice.type == 'must_acknowledge' %}selected{% endif %}>{{ t('notices.must_acknowledge') }}</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label" for="content">{{ t('notices.content') }}</label>
            <textarea class="form-control" id="content" name="content" rows="6">{{ notice.content|default('') }}</textarea>
        </div>

        <div class="d-flex justify-content-between">
            <a href="{{ route('admin.notices') }}" class="btn btn-outline-secondary">{{ t('common.cancel') }}</a>
            <button class="btn btn-primary">{{ isEdit ? t('common.save') : t('common.create') }}</button>
        </div>
    </form>
</div>
{% endblock %}
