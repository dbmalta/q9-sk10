{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.notices') }}{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">{{ t('nav.notices') }}</h1>
        <a class="btn btn-primary" href="{{ route('admin.notices.create') }}">
            <i class="bi bi-plus-lg me-1"></i>{{ t('notices.create') }}
        </a>
    </div>

    <div class="card">
        <table class="table mb-0">
            <thead><tr><th>{{ t('notices.title') }}</th><th>{{ t('notices.type') }}</th><th>{{ t('notices.active') }}</th><th></th></tr></thead>
            <tbody>
            {% for n in notices %}
                <tr>
                    <td>{{ n.title }}</td>
                    <td><span class="badge bg-secondary">{{ n.type }}</span></td>
                    <td>{% if n.is_active %}<i class="bi bi-check-lg text-success"></i>{% endif %}</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" href="{{ route('admin.notices.edit', {id: n.id}) }}">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% if n.is_active %}
                        <form method="post" action="{{ route('admin.notices.deactivate', {id: n.id}) }}" class="d-inline">
                            {{ csrf_field()|raw }}
                            <button class="btn btn-sm btn-outline-danger">{{ t('notices.deactivate') }}</button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-center text-muted py-3">{{ t('common.none') }}</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
