{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.terms') }}{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">{{ t('nav.terms') }}</h1>
        <a class="btn btn-primary" href="{{ route('admin.terms.create') }}">
            <i class="bi bi-plus-lg me-1"></i>{{ t('terms.create') }}
        </a>
    </div>

    <div class="card">
        <table class="table mb-0">
            <thead><tr><th>{{ t('terms.version') }}</th><th>{{ t('terms.title') }}</th><th>{{ t('terms.published') }}</th><th></th></tr></thead>
            <tbody>
            {% for v in versions %}
                <tr>
                    <td><code>{{ v.version_number }}</code></td>
                    <td>{{ v.title }}</td>
                    <td>
                        {% if v.is_published %}
                            <i class="bi bi-check-circle text-success"></i> {{ v.published_at }}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" href="{{ route('admin.terms.edit', {id: v.id}) }}">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% if not v.is_published %}
                        <form method="post" action="{{ route('admin.terms.publish', {id: v.id}) }}" class="d-inline">
                            {{ csrf_field()|raw }}
                            <button class="btn btn-sm btn-success">{{ t('terms.publish') }}</button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-center text-muted py-3">{{ t('common.none') }}</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
