{% extends "layouts/admin.html.twig" %}

{% set isEdit = version is not null %}

{% block title %}{{ isEdit ? t('terms.edit') : t('terms.create') }}{% endblock %}

{% block content %}
<div class="container py-4" style="max-width: 900px;">
    <h1 class="h3 mb-4">{{ isEdit ? t('terms.edit') : t('terms.create') }}</h1>

    <form method="post" action="{{ isEdit ? route('admin.terms.update', {id: version.id}) : route('admin.terms.store') }}">
        {{ csrf_field()|raw }}

        <div class="row mb-3">
            <div class="col-md-9">
                <label class="form-label" for="title">{{ t('terms.title') }}</label>
                <input type="text" class="form-control" id="title" name="title"
                       value="{{ version.title|default('') }}" required>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="version_number">{{ t('terms.version') }}</label>
                <input type="text" class="form-control" id="version_number" name="version_number"
                       value="{{ version.version_number|default('1.0') }}" required>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label" for="grace_period_days">{{ t('terms.grace_period_days') }}</label>
            <input type="number" class="form-control" id="grace_period_days" name="grace_period_days"
                   value="{{ version.grace_period_days|default(14) }}" min="0" style="max-width: 10rem;">
        </div>

        <div class="mb-3">
            <label class="form-label" for="content">{{ t('terms.content') }}</label>
            <textarea class="form-control" id="content" name="content" rows="12">{{ version.content|default('') }}</textarea>
        </div>

        <div class="d-flex justify-content-between">
            <a href="{{ route('admin.terms') }}" class="btn btn-outline-secondary">{{ t('common.cancel') }}</a>
            <button class="btn btn-primary">{{ isEdit ? t('common.save') : t('common.create') }}</button>
        </div>
    </form>
</div>
{% endblock %}
