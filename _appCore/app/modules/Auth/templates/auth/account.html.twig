{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('auth.account') }}{% endblock %}

{% block content %}
<div class="container py-4">
    <h1 class="h3 mb-4">{{ t('auth.account') }}</h1>

    <div class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">{{ t('auth.email') }}</dt>
                <dd class="col-sm-9">{{ email }}</dd>
            </dl>
        </div>
    </div>

    <form method="post" action="{{ route('auth.logout') }}" class="mt-3">
        {{ csrf_field()|raw }}
        <button type="submit" class="btn btn-outline-secondary">
            <i class="bi bi-box-arrow-right me-1"></i>{{ t('auth.logout') }}
        </button>
    </form>
</div>
{% endblock %}
