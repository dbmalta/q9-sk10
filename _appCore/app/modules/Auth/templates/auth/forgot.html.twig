{% extends "layouts/auth.html.twig" %}

{% block title %}{{ t('auth.forgot_password') }}{% endblock %}

{% block body %}
<h1 class="h5 mb-4 text-center">{{ t('auth.forgot_password') }}</h1>
<p class="small text-muted mb-3 text-center">{{ t('auth.forgot_prompt') }}</p>

<form method="post" action="{{ route('auth.forgot.process') }}">
    {{ csrf_field()|raw }}
    <div class="mb-3">
        <label for="email" class="form-label">{{ t('auth.email') }}</label>
        <input type="email" name="email" id="email" class="form-control" required autofocus>
    </div>
    <button type="submit" class="btn btn-primary w-100 mb-2">{{ t('auth.send_reset') }}</button>
    <div class="text-center small">
        <a href="{{ route('auth.login') }}">{{ t('auth.back_to_login') }}</a>
    </div>
</form>
{% endblock %}
