{% extends "layouts/auth.html.twig" %}

{% block title %}{{ t('auth.login') }}{% endblock %}

{% block body %}
<h1 class="h5 mb-4 text-center">{{ t('auth.login') }}</h1>

<form method="post" action="{{ route('auth.login.process') }}">
    {{ csrf_field()|raw }}

    <div class="mb-3">
        <label for="email" class="form-label">{{ t('auth.email') }}</label>
        <input type="email" name="email" id="email" class="form-control"
               value="{{ email|default('') }}" required autofocus>
    </div>

    <div class="mb-3">
        <label for="password" class="form-label">{{ t('auth.password') }}</label>
        <input type="password" name="password" id="password" class="form-control" required>
    </div>

    <button type="submit" class="btn btn-primary w-100 mb-2">{{ t('auth.login') }}</button>

    <div class="text-center small">
        <a href="{{ route('auth.forgot') }}">{{ t('auth.forgot_password') }}</a>
    </div>
</form>
{% endblock %}
