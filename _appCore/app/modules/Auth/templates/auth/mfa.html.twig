{% extends "layouts/auth.html.twig" %}

{% block title %}{{ t('auth.mfa') }}{% endblock %}

{% block body %}
<h1 class="h5 mb-4 text-center">{{ t('auth.mfa') }}</h1>
<p class="small text-muted mb-3 text-center">{{ t('auth.mfa_prompt') }}</p>

<form method="post" action="{{ route('auth.mfa.process') }}">
    {{ csrf_field()|raw }}
    <div class="mb-3">
        <label for="code" class="form-label">{{ t('auth.code') }}</label>
        <input type="text" name="code" id="code" class="form-control text-center"
               inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autofocus>
    </div>
    <button type="submit" class="btn btn-primary w-100">{{ t('auth.verify') }}</button>
</form>
{% endblock %}
