{% extends "layouts/auth.html.twig" %}

{% block title %}{{ t('auth.reset_password') }}{% endblock %}

{% block body %}
<h1 class="h5 mb-4 text-center">{{ t('auth.reset_password') }}</h1>
<p class="small text-muted mb-3 text-center">{{ email }}</p>

<form method="post" action="{{ route('auth.reset.process', {token: token}) }}">
    {{ csrf_field()|raw }}
    <div class="mb-3">
        <label for="password" class="form-label">{{ t('auth.new_password') }}</label>
        <input type="password" name="password" id="password" class="form-control" minlength="10" required>
    </div>
    <div class="mb-3">
        <label for="password_confirm" class="form-label">{{ t('auth.confirm_password') }}</label>
        <input type="password" name="password_confirm" id="password_confirm" class="form-control" minlength="10" required>
    </div>
    <button type="submit" class="btn btn-primary w-100">{{ t('auth.set_password') }}</button>
</form>
{% endblock %}
