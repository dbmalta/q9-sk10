{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('permissions.assignments') }}{% endblock %}

{% block content %}
<div class="container py-4">
    <h1 class="h3 mb-4">
        {{ t('permissions.assignments_for') }}: {{ user.email|default('—') }}
    </h1>

    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5 mb-3">{{ t('permissions.active_assignments') }}</h2>
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>{{ t('permissions.role') }}</th>
                        <th>{{ t('permissions.start_date') }}</th>
                        <th>{{ t('permissions.end_date') }}</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                {% for a in assignments %}
                    <tr>
                        <td><strong>{{ a.role_name }}</strong><div class="small text-muted">{{ a.role_description }}</div></td>
                        <td>{{ a.start_date }}</td>
                        <td>{{ a.end_date|default('—') }}</td>
                        <td class="text-end">
                        {% if not a.end_date and has_permission('roles.write') %}
                            <form method="post" action="{{ route('permissions.assignments.end', {id: a.id}) }}" class="d-inline">
                                {{ csrf_field()|raw }}
                                <button class="btn btn-sm btn-outline-danger">{{ t('permissions.end_assignment') }}</button>
                            </form>
                        {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="4" class="text-center text-muted py-3">{{ t('permissions.no_assignments') }}</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if has_permission('roles.write') %}
    <div class="card">
        <div class="card-body">
            <h2 class="h5 mb-3">{{ t('permissions.new_assignment') }}</h2>
            <form method="post" action="{{ route('permissions.assignments.store', {userId: user.id}) }}">
                {{ csrf_field()|raw }}
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label" for="role_id">{{ t('permissions.role') }}</label>
                        <select name="role_id" id="role_id" class="form-select" required>
                            <option value="">—</option>
                            {% for r in roles %}
                                <option value="{{ r.id }}">{{ r.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" for="start_date">{{ t('permissions.start_date') }}</label>
                        <input type="date" class="form-control" name="start_date" id="start_date">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" for="end_date">{{ t('permissions.end_date') }}</label>
                        <input type="date" class="form-control" name="end_date" id="end_date">
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button class="btn btn-primary w-100">{{ t('common.add') }}</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
