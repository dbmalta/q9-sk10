{# Usage: {% include 'components/_pagination.html.twig' with {page: page, per_page: per_page, total: total, base_url: '/admin/audit'} %} #}
{% set total_pages = (total / per_page)|round(0, 'ceil') %}
{% if total_pages > 1 %}
<nav aria-label="pagination" class="mt-3">
    <ul class="pagination">
        {% for p in 1..total_pages %}
            <li class="page-item {{ p == page ? 'active' : '' }}">
                <a class="page-link" href="{{ base_url }}?page={{ p }}">{{ p }}</a>
            </li>
        {% endfor %}
    </ul>
</nav>
{% endif %}
