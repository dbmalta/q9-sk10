{% extends "layouts/base.html.twig" %}

{% block body_wrapper %}
<div class="d-flex min-vh-100">
    {# Sidebar #}
    <aside class="bg-body-tertiary border-end" style="width: 260px; flex-shrink: 0;">
        <div class="p-3 border-bottom">
            <a href="{{ route('home') }}" class="text-decoration-none text-body fw-semibold">
                {{ app_name|default('appCore') }}
            </a>
        </div>

        <nav class="p-2">
            {% for groupId, items in nav_items %}
                {% if groupId != '_top' %}
                    <div class="text-uppercase small text-body-secondary px-2 mt-3 mb-1">{{ t('nav.group.' ~ groupId) }}</div>
                {% endif %}
                {% for item in items %}
                    <a class="nav-link d-flex align-items-center px-2 py-1 {{ current_uri starts with item.route ? 'fw-semibold' : '' }}"
                       href="{{ item.route }}">
                        <i class="bi {{ item.icon }} me-2"></i>
                        <span>{{ t(item.label) }}</span>
                        {% if item.badge %}
                            <span class="badge bg-secondary ms-auto">{{ item.badge }}</span>
                        {% endif %}
                    </a>
                {% endfor %}
            {% endfor %}
        </nav>
    </aside>

    {# Main content area #}
    <div class="flex-grow-1 d-flex flex-column">
        {# Topbar #}
        <header class="d-flex align-items-center justify-content-end gap-3 px-4 py-2 border-bottom bg-body">
            {# Language switcher #}
            <div class="dropdown">
                <button class="btn btn-sm btn-link text-body-secondary" data-bs-toggle="dropdown">
                    <i class="bi bi-globe2 me-1"></i>{{ app_lang|upper }}
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    {% for lang in available_languages() %}
                    <li>
                        <form method="POST" action="{{ route('language.switch') }}" class="m-0">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <input type="hidden" name="code" value="{{ lang.code }}">
                            <input type="hidden" name="redirect_to" value="{{ current_uri }}">
                            <button type="submit" class="dropdown-item {{ lang.code == app_lang ? 'active' : '' }}">
                                <span class="text-uppercase small me-2">{{ lang.code }}</span>{{ lang.native_name }}
                            </button>
                        </form>
                    </li>
                    {% endfor %}
                </ul>
            </div>

            {% if user %}
            <div class="dropdown">
                <button class="btn btn-sm btn-link text-body" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle me-1"></i>{{ user.email }}
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="{{ route('auth.account') }}">{{ t('auth.account') }}</a></li>
                    <li>
                        <form method="POST" action="{{ route('auth.logout') }}" class="m-0">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button class="dropdown-item">{{ t('auth.logout') }}</button>
                        </form>
                    </li>
                </ul>
            </div>
            {% endif %}
        </header>

        {# Flash messages + content #}
        <main id="main-content" class="flex-grow-1">
            {% set flashes = flash() %}
            {% if flashes is not empty %}
            <div class="container-fluid px-4 pt-3">
                {% for type, messages in flashes %}
                    {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                    {% endfor %}
                {% endfor %}
            </div>
            {% endif %}

            {% if breadcrumbs is defined and breadcrumbs|length > 0 %}
                {% include "components/_breadcrumbs.html.twig" ignore missing %}
            {% endif %}

            {% block content %}{% endblock %}
        </main>

        {% include "components/_footer.html.twig" ignore missing %}
    </div>
</div>
{% endblock %}
