{% extends "layouts/base.html.twig" %}

{% block body_wrapper %}
<div class="d-flex flex-column align-items-center justify-content-center min-vh-100 p-4 bg-body-tertiary">
    <div class="text-center mb-4">
        <h1 class="h4 fw-semibold mb-1">{{ app_name|default('appCore') }}</h1>
    </div>

    <div class="card shadow-sm border-0" style="max-width: 420px; width: 100%;">
        <div class="card-body p-4">
            {% set flashes = flash() %}
            {% if flashes is not empty %}
                {% for type, messages in flashes %}
                    {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} py-2 px-3 small" role="alert">
                        {{ message }}
                    </div>
                    {% endfor %}
                {% endfor %}
            {% endif %}

            <main id="main-content">
                {% block body %}{% endblock %}
            </main>
        </div>
    </div>

    <div class="mt-4 text-center text-body-secondary small">
        <span class="fw-semibold">{{ app_name|default('appCore') }}</span> v{{ app_version|default('0.0.0') }}
    </div>
</div>
{% endblock %}
