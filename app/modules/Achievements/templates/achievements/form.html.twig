{% extends "layouts/admin.html.twig" %}

{% block title %}{{ definition ? t('common.edit') : t('achievements.create') }}{% endblock %}

{% block body %}
<h1 class="h3 mb-4">{{ definition ? t('common.edit') ~ ': ' ~ definition.name : t('achievements.create') }}</h1>

<form method="POST" action="{{ definition ? '/admin/achievements/' ~ definition.id : '/admin/achievements' }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token }}">

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="mb-3">
                <label for="name" class="form-label">{{ t('common.name') }} <span class="text-danger">*</span></label>
                <input type="text" name="name" id="name" class="form-control" required
                       value="{{ definition.name|default('') }}">
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">{{ t('common.description') }}</label>
                <textarea name="description" id="description" class="form-control" rows="3">{{ definition.description|default('') }}</textarea>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label for="category" class="form-label">{{ t('achievements.category') }} <span class="text-danger">*</span></label>
                    <select name="category" id="category" class="form-select" required>
                        <option value="achievement" {{ (definition.category|default('achievement')) == 'achievement' ? 'selected' : '' }}>{{ t('achievements.category_achievement') }}</option>
                        <option value="training" {{ (definition.category|default('')) == 'training' ? 'selected' : '' }}>{{ t('achievements.category_training') }}</option>
                    </select>
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check">
                        <input type="checkbox" name="is_active" id="is_active" class="form-check-input" value="1"
                               {{ (definition.is_active is not defined or definition.is_active) ? 'checked' : '' }}>
                        <label for="is_active" class="form-check-label">{{ t('common.active') }}</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>{{ t('common.save') }}
        </button>
        <a href="/admin/achievements" class="btn btn-outline-secondary">{{ t('common.cancel') }}</a>
    </div>
</form>
{% endblock %}
