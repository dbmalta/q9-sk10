{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('audit.entity_trail') }}: {{ entity_type }} #{{ entity_id }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('audit.entity_trail') }}: {{ entity_type }} #{{ entity_id }}</h1>
    <a href="/admin/audit" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>{{ t('common.back') }}
    </a>
</div>

{% if entries is empty %}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-clock-history text-body-secondary" style="font-size: 2.5rem;"></i>
        <p class="mt-3 text-body-secondary">{{ t('audit.no_trail_entries') }}</p>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('audit.date') }}</th>
                    <th>{{ t('audit.user') }}</th>
                    <th>{{ t('audit.action') }}</th>
                    <th>{{ t('audit.old_values') }}</th>
                    <th class="pe-3">{{ t('audit.new_values') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in entries %}
                <tr>
                    <td class="ps-3 small">{{ entry.created_at|date('d M Y H:i:s') }}</td>
                    <td class="small">{{ entry.user_email|default('—') }}</td>
                    <td>
                        <span class="badge bg-{{ entry.action == 'create' ? 'success' : (entry.action == 'delete' ? 'danger' : (entry.action == 'update' ? 'info' : 'secondary')) }}">
                            {{ entry.action }}
                        </span>
                    </td>
                    <td>
                        {% if entry.old_values %}
                        <pre class="mb-0 small bg-body-tertiary p-2 rounded" style="max-width: 300px; max-height: 150px; overflow: auto;">{{ entry.old_values|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                        {% else %}
                        <span class="text-body-secondary">—</span>
                        {% endif %}
                    </td>
                    <td class="pe-3">
                        {% if entry.new_values %}
                        <pre class="mb-0 small bg-body-tertiary p-2 rounded" style="max-width: 300px; max-height: 150px; overflow: auto;">{{ entry.new_values|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                        {% else %}
                        <span class="text-body-secondary">—</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
