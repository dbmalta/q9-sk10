{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('audit.title') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('audit.title') }}</h1>
</div>

{# Filter row #}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="GET" action="/admin/audit" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label for="filter-action" class="form-label small">{{ t('audit.action') }}</label>
                <select name="action" id="filter-action" class="form-select form-select-sm">
                    <option value="">{{ t('common.all') }}</option>
                    {% for action in actions %}
                    <option value="{{ action }}" {{ filters.action == action ? 'selected' : '' }}>{{ action }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label for="filter-entity-type" class="form-label small">{{ t('audit.entity_type') }}</label>
                <select name="entity_type" id="filter-entity-type" class="form-select form-select-sm">
                    <option value="">{{ t('common.all') }}</option>
                    {% for type in entity_types %}
                    <option value="{{ type }}" {{ filters.entity_type == type ? 'selected' : '' }}>{{ type }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label for="filter-date-from" class="form-label small">{{ t('audit.date_from') }}</label>
                <input type="date" name="date_from" id="filter-date-from" class="form-control form-control-sm" value="{{ filters.date_from }}">
            </div>
            <div class="col-md-2">
                <label for="filter-date-to" class="form-label small">{{ t('audit.date_to') }}</label>
                <input type="date" name="date_to" id="filter-date-to" class="form-control form-control-sm" value="{{ filters.date_to }}">
            </div>
            <div class="col-md-auto d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-funnel me-1"></i>{{ t('common.filter') }}
                </button>
                <a href="/admin/audit" class="btn btn-outline-secondary btn-sm">{{ t('common.clear') }}</a>
            </div>
        </form>
    </div>
</div>

{# Audit log table #}
{% if entries is empty %}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-shield-check text-body-secondary" style="font-size: 2.5rem;"></i>
        <p class="mt-3 text-body-secondary">{{ t('audit.no_entries') }}</p>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('audit.date') }}</th>
                    <th>{{ t('audit.user') }}</th>
                    <th>{{ t('audit.action') }}</th>
                    <th>{{ t('audit.entity_type') }}</th>
                    <th>{{ t('audit.entity_id') }}</th>
                    <th class="text-end pe-3">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in entries %}
                <tr>
                    <td class="ps-3 small">{{ entry.created_at|date('d M Y H:i:s') }}</td>
                    <td class="small">{{ entry.user_email|default('—') }}</td>
                    <td>
                        <span class="badge bg-{{ entry.action == 'create' ? 'success' : (entry.action == 'delete' ? 'danger' : (entry.action == 'update' ? 'info' : 'secondary')) }}">
                            {{ entry.action }}
                        </span>
                    </td>
                    <td class="small">{{ entry.entity_type }}</td>
                    <td class="small">{{ entry.entity_id|default('—') }}</td>
                    <td class="text-end pe-3">
                        {% if entry.entity_type and entry.entity_id %}
                        <a href="/admin/audit/{{ entry.entity_type }}/{{ entry.entity_id }}" class="btn btn-sm btn-outline-secondary" title="{{ t('audit.view_trail') }}">
                            <i class="bi bi-clock-history"></i>
                        </a>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# Pagination #}
{% if pagination.pages > 1 %}
<div class="mt-4">
    {% set base_url = '/admin/audit?' %}
    {% if filters.action %}{% set base_url = base_url ~ 'action=' ~ filters.action ~ '&' %}{% endif %}
    {% if filters.entity_type %}{% set base_url = base_url ~ 'entity_type=' ~ filters.entity_type ~ '&' %}{% endif %}
    {% if filters.date_from %}{% set base_url = base_url ~ 'date_from=' ~ filters.date_from ~ '&' %}{% endif %}
    {% if filters.date_to %}{% set base_url = base_url ~ 'date_to=' ~ filters.date_to ~ '&' %}{% endif %}
    {% include "components/_pagination.html.twig" with {
        current_page: pagination.page,
        total_pages: pagination.pages,
        base_url: base_url
    } %}
</div>
{% endif %}
{% endif %}
{% endblock %}
