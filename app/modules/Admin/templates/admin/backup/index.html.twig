{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('backup.title') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('backup.title') }}</h1>
    <form method="POST" action="/admin/backups/create" class="d-inline">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>{{ t('backup.create') }}
        </button>
    </form>
</div>

{% if backups is empty %}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-archive text-body-secondary" style="font-size: 2.5rem;"></i>
        <p class="mt-3 text-body-secondary">{{ t('backup.no_backups') }}</p>
        <form method="POST" action="/admin/backups/create" class="d-inline">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-primary btn-sm">{{ t('backup.create') }}</button>
        </form>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('backup.filename') }}</th>
                    <th>{{ t('backup.size') }}</th>
                    <th>{{ t('backup.created_at') }}</th>
                    <th class="text-end pe-3">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for backup in backups %}
                <tr>
                    <td class="ps-3">
                        <i class="bi bi-file-earmark-zip me-1 text-body-secondary"></i>
                        <span class="small">{{ backup.filename }}</span>
                    </td>
                    <td class="small">{{ backup.size_human }}</td>
                    <td class="small">{{ backup.date|date('d M Y H:i:s') }}</td>
                    <td class="text-end pe-3">
                        <a href="/admin/backups/{{ backup.filename }}" class="btn btn-sm btn-outline-primary" title="{{ t('common.download') }}">
                            <i class="bi bi-download"></i>
                        </a>
                        <form method="POST" action="/admin/backups/{{ backup.filename }}/delete" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="{{ t('common.delete') }}"
                                    onclick="return confirm('{{ t('common.confirm_delete') }}')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
