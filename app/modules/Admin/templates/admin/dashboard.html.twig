{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.dashboard') }}{% endblock %}

{% block body %}
<h1 class="h3 mb-4">{{ t('nav.dashboard') }}</h1>

{# ── Stat cards ─────────────────────────────────────────────── #}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <span class="bg-primary bg-opacity-10 text-primary rounded-3 p-3 d-inline-flex">
                            <i class="bi bi-people-fill fs-4"></i>
                        </span>
                    </div>
                    <div class="ms-3">
                        <div class="text-body-secondary small">{{ t('dashboard.total_members') }}</div>
                        <div class="fs-4 fw-semibold">{{ stats.total_members }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <span class="bg-warning bg-opacity-10 text-warning rounded-3 p-3 d-inline-flex">
                            <i class="bi bi-person-plus-fill fs-4"></i>
                        </span>
                    </div>
                    <div class="ms-3">
                        <div class="text-body-secondary small">{{ t('dashboard.pending_registrations') }}</div>
                        <div class="fs-4 fw-semibold">{{ stats.recent_registrations|length }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <span class="bg-info bg-opacity-10 text-info rounded-3 p-3 d-inline-flex">
                            <i class="bi bi-hourglass-split fs-4"></i>
                        </span>
                    </div>
                    <div class="ms-3">
                        <div class="text-body-secondary small">{{ t('dashboard.waiting_list') }}</div>
                        <div class="fs-4 fw-semibold">{{ stats.waiting_list_count }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <span class="bg-success bg-opacity-10 text-success rounded-3 p-3 d-inline-flex">
                            <i class="bi bi-calendar-event fs-4"></i>
                        </span>
                    </div>
                    <div class="ms-3">
                        <div class="text-body-secondary small">{{ t('dashboard.upcoming_events') }}</div>
                        <div class="fs-4 fw-semibold">{{ stats.upcoming_events|length }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Two-column layout ──────────────────────────────────────── #}
<div class="row g-4 mb-4">
    {# Recent Registrations #}
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h2 class="h6 mb-0">{{ t('dashboard.recent_registrations') }}</h2>
                <a href="/admin/registrations" class="btn btn-sm btn-outline-secondary">
                    {{ t('common.view_all') }}
                </a>
            </div>
            {% if stats.recent_registrations is empty %}
            <div class="card-body text-center py-4">
                <p class="text-body-secondary mb-0">{{ t('dashboard.no_pending_registrations') }}</p>
            </div>
            {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3">{{ t('common.name') }}</th>
                            <th>{{ t('common.email') }}</th>
                            <th>{{ t('common.date') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for reg in stats.recent_registrations %}
                        <tr>
                            <td class="ps-3">{{ reg.first_name }} {{ reg.surname }}</td>
                            <td class="small">{{ reg.email|default('—') }}</td>
                            <td class="small">{{ reg.created_at|date('d M Y') }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
        </div>
    </div>

    {# System Health #}
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent">
                <h2 class="h6 mb-0">{{ t('dashboard.system_health') }}</h2>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <tbody>
                        <tr>
                            <td class="ps-3 text-body-secondary">{{ t('dashboard.php_version') }}</td>
                            <td class="text-end pe-3 fw-medium">{{ health.php_version }}</td>
                        </tr>
                        <tr>
                            <td class="ps-3 text-body-secondary">{{ t('dashboard.db_size') }}</td>
                            <td class="text-end pe-3 fw-medium">{{ health.db_size }}</td>
                        </tr>
                        <tr>
                            <td class="ps-3 text-body-secondary">{{ t('dashboard.last_cron_run') }}</td>
                            <td class="text-end pe-3 fw-medium">
                                {% if health.last_cron_run %}
                                    {{ health.last_cron_run|date('d M Y H:i') }}
                                {% else %}
                                    <span class="text-body-secondary">{{ t('common.never') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="ps-3 text-body-secondary">{{ t('dashboard.error_count') }}</td>
                            <td class="text-end pe-3">
                                {% if health.error_count > 0 %}
                                    <a href="/admin/logs" class="badge bg-danger text-decoration-none">{{ health.error_count }}</a>
                                {% else %}
                                    <span class="badge bg-success">0</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="ps-3 text-body-secondary">{{ t('dashboard.app_version') }}</td>
                            <td class="text-end pe-3 fw-medium">{{ health.app_version }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{# ── Members by status ──────────────────────────────────────── #}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent">
        <h2 class="h6 mb-0">{{ t('dashboard.members_by_status') }}</h2>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('common.status') }}</th>
                    <th class="text-end pe-3">{{ t('common.count') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for status, count in stats.members_by_status %}
                <tr>
                    <td class="ps-3">
                        <span class="badge bg-{{ status == 'active' ? 'success' : (status == 'pending' ? 'warning' : (status == 'suspended' ? 'danger' : 'secondary')) }}">
                            {{ status|capitalize }}
                        </span>
                    </td>
                    <td class="text-end pe-3 fw-medium">{{ count }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
