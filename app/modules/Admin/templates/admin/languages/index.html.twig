{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('languages.title') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('languages.title') }}</h1>
    <div>
        <a href="/admin/languages/export-master" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-download me-1"></i>{{ t('languages.export_master') }}
        </a>
        <a href="/admin/languages/upload" class="btn btn-primary btn-sm">
            <i class="bi bi-upload me-1"></i>{{ t('languages.upload') }}
        </a>
    </div>
</div>

{% if languages is empty %}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-translate text-body-secondary" style="font-size: 2.5rem;"></i>
        <p class="mt-3 text-body-secondary">{{ t('languages.no_languages') }}</p>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('languages.code') }}</th>
                    <th>{{ t('languages.name') }}</th>
                    <th>{{ t('languages.native_name') }}</th>
                    <th>{{ t('languages.completion') }}</th>
                    <th>{{ t('languages.is_active') }}</th>
                    <th>{{ t('languages.is_default') }}</th>
                    <th class="text-end pe-3">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for lang in languages %}
                <tr>
                    <td class="ps-3"><code>{{ lang.code }}</code></td>
                    <td>{{ lang.name }}</td>
                    <td>{{ lang.native_name }}</td>
                    <td style="min-width: 120px;">
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-success" role="progressbar"
                                 style="width: {{ lang.completion|default(0) }}%"
                                 aria-valuenow="{{ lang.completion|default(0) }}" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-body-secondary">{{ lang.completion|default(0) }}%</small>
                    </td>
                    <td>
                        {% if lang.is_active %}
                            <span class="badge bg-success">{{ t('languages.is_active') }}</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ t('common.no') }}</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if lang.is_default %}
                            <span class="badge bg-primary">{{ t('languages.is_default') }}</span>
                        {% endif %}
                    </td>
                    <td class="text-end pe-3">
                        <a href="/admin/languages/{{ lang.code }}/strings" class="btn btn-sm btn-outline-primary" title="{{ t('languages.strings') }}">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        {% if not lang.is_default %}
                        <form method="POST" action="/admin/languages/{{ lang.code }}/default" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="{{ t('languages.set_default') }}">
                                <i class="bi bi-star"></i>
                            </button>
                        </form>
                        {% endif %}
                        {% if lang.is_active %}
                        <form method="POST" action="/admin/languages/{{ lang.code }}/deactivate" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="{{ t('languages.deactivate') }}">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </form>
                        {% else %}
                        <form method="POST" action="/admin/languages/{{ lang.code }}/activate" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-success" title="{{ t('languages.activate') }}">
                                <i class="bi bi-check-circle"></i>
                            </button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
