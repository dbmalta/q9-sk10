{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.notices') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('nav.notices') }}</h1>
    <a href="/admin/notices/create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>{{ t('notices.create') }}
    </a>
</div>

{% if notices is empty %}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-bell text-body-secondary" style="font-size: 2.5rem;"></i>
        <p class="mt-3 text-body-secondary">{{ t('notices.no_notices') }}</p>
        <a href="/admin/notices/create" class="btn btn-primary btn-sm">{{ t('notices.create') }}</a>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('notices.title') }}</th>
                    <th>{{ t('notices.type') }}</th>
                    <th>{{ t('notices.is_active') }}</th>
                    <th>{{ t('common.created_at') }}</th>
                    <th class="text-end pe-3">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for notice in notices %}
                <tr>
                    <td class="ps-3">{{ notice.title }}</td>
                    <td>
                        {% if notice.type == 'must_acknowledge' %}
                            <span class="badge bg-warning text-dark">{{ t('notices.type_must_acknowledge') }}</span>
                        {% else %}
                            <span class="badge bg-info text-dark">{{ t('notices.type_informational') }}</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if notice.is_active %}
                            <span class="badge bg-success">{{ t('notices.is_active') }}</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ t('notices.inactive') }}</span>
                        {% endif %}
                    </td>
                    <td class="small">{{ notice.created_at|date('d M Y H:i') }}</td>
                    <td class="text-end pe-3">
                        <a href="/admin/notices/{{ notice.id }}/edit" class="btn btn-sm btn-outline-primary" title="{{ t('common.edit') }}">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="/admin/notices/{{ notice.id }}/acknowledgements" class="btn btn-sm btn-outline-secondary" title="{{ t('notices.acknowledgements') }}">
                            <i class="bi bi-check2-all"></i>
                        </a>
                        {% if notice.is_active %}
                        <form method="POST" action="/admin/notices/{{ notice.id }}/deactivate" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="{{ t('notices.deactivate') }}">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
