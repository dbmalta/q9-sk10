{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('reports.growth') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('reports.growth') }}</h1>
    <a href="/admin/reports" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>{{ t('common.back') }}
    </a>
</div>

{# ── Filter form ────────────────────────────────────────────── #}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="GET" action="/admin/reports/growth" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="interval" class="form-label">{{ t('reports.interval') }}</label>
                <select name="interval" id="interval" class="form-select">
                    <option value="month" {{ interval == 'month' ? 'selected' : '' }}>{{ t('reports.interval_month') }}</option>
                    <option value="quarter" {{ interval == 'quarter' ? 'selected' : '' }}>{{ t('reports.interval_quarter') }}</option>
                    <option value="year" {{ interval == 'year' ? 'selected' : '' }}>{{ t('reports.interval_year') }}</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="start_date" class="form-label">{{ t('reports.start_date') }}</label>
                <input type="date" name="start_date" id="start_date" class="form-control" value="{{ start_date|default('') }}">
            </div>
            <div class="col-md-3">
                <label for="end_date" class="form-label">{{ t('reports.end_date') }}</label>
                <input type="date" name="end_date" id="end_date" class="form-control" value="{{ end_date|default('') }}">
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-funnel me-1"></i>{{ t('common.filter') }}
                </button>
            </div>
        </form>
    </div>
</div>

{# ── Results table ──────────────────────────────────────────── #}
{% if growth is empty %}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-graph-up text-body-secondary" style="font-size: 2.5rem;"></i>
        <p class="mt-3 text-body-secondary">{{ t('reports.no_data') }}</p>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('reports.period') }}</th>
                    <th class="text-end pe-3">{{ t('reports.new_members') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for row in growth %}
                <tr>
                    <td class="ps-3">{{ row.period }}</td>
                    <td class="text-end pe-3 fw-medium">{{ row.count }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
