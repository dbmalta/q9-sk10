{% extends "layouts/admin.html.twig" %}

{% block title %}{{ version ? t('common.edit') : t('terms.create') }} — {{ t('nav.terms') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ version ? t('common.edit') : t('terms.create') }}</h1>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="POST" action="{{ version ? '/admin/terms/' ~ version.id : '/admin/terms' }}">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">

            <div class="row g-3">
                <div class="col-md-8">
                    <label for="title" class="form-label">{{ t('terms.title') }}</label>
                    <input type="text" name="title" id="title" class="form-control"
                           value="{{ version.title|default('') }}" required>
                </div>
                <div class="col-md-4">
                    <label for="version_number" class="form-label">{{ t('terms.version_number') }}</label>
                    <input type="text" name="version_number" id="version_number" class="form-control"
                           value="{{ version.version_number|default('') }}" required>
                </div>
                <div class="col-12">
                    <label for="content" class="form-label">{{ t('terms.content') }}</label>
                    <textarea name="content" id="content" class="form-control" rows="12" required>{{ version.content|default('') }}</textarea>
                </div>
                <div class="col-md-4">
                    <label for="grace_period_days" class="form-label">{{ t('terms.grace_period_days') }}</label>
                    <input type="number" name="grace_period_days" id="grace_period_days" class="form-control"
                           value="{{ version.grace_period_days|default(14) }}" min="0">
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>{{ t('common.save') }}
                </button>
                <a href="/admin/terms" class="btn btn-link">{{ t('common.cancel') }}</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
