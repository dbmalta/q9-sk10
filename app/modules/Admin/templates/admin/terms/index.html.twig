{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.terms') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('nav.terms') }}</h1>
    <a href="/admin/terms/create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>{{ t('terms.create') }}
    </a>
</div>

{% if versions is empty %}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-file-earmark-text text-body-secondary" style="font-size: 2.5rem;"></i>
        <p class="mt-3 text-body-secondary">{{ t('terms.no_versions') }}</p>
        <a href="/admin/terms/create" class="btn btn-primary btn-sm">{{ t('terms.create') }}</a>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('terms.title') }}</th>
                    <th>{{ t('terms.version_number') }}</th>
                    <th>{{ t('terms.is_published') }}</th>
                    <th>{{ t('terms.published_at') }}</th>
                    <th class="text-end pe-3">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for version in versions %}
                <tr>
                    <td class="ps-3">
                        <a href="/admin/terms/{{ version.id }}">{{ version.title }}</a>
                    </td>
                    <td><code>{{ version.version_number }}</code></td>
                    <td>
                        {% if version.is_published %}
                            <span class="badge bg-success">{{ t('terms.is_published') }}</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ t('terms.draft') }}</span>
                        {% endif %}
                    </td>
                    <td class="small">{{ version.published_at ? version.published_at|date('d M Y H:i') : '—' }}</td>
                    <td class="text-end pe-3">
                        <a href="/admin/terms/{{ version.id }}/edit" class="btn btn-sm btn-outline-primary" title="{{ t('common.edit') }}">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% if not version.is_published %}
                        <form method="POST" action="/admin/terms/{{ version.id }}/publish" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-success" title="{{ t('terms.publish') }}">
                                <i class="bi bi-check-circle"></i>
                            </button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
