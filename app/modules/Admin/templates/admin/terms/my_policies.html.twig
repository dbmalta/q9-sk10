{% extends "layouts/member.html.twig" %}

{% block title %}{{ t('policies.my_title') }}{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="h3 mb-4">{{ t('policies.my_title') }}</h1>

    {% if outstanding is not empty %}
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-warning-subtle">
            <h2 class="h6 mb-0 text-warning-emphasis">
                <i class="bi bi-exclamation-triangle me-1"></i>
                {{ t('policies.my_outstanding', {count: outstanding|length}) }}
            </h2>
        </div>
        <ul class="list-group list-group-flush">
            {% for item in outstanding %}
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <div class="fw-semibold">{{ item.policy_name }}</div>
                    <div class="small text-body-secondary">{{ item.version_title }} <code>{{ item.version_number }}</code></div>
                </div>
                <a href="/my/policies/versions/{{ item.version_id }}" class="btn btn-primary btn-sm">
                    {{ t('policies.review_and_accept') }}
                </a>
            </li>
            {% endfor %}
        </ul>
    </div>
    {% else %}
    <div class="alert alert-success border-0 shadow-sm">
        <i class="bi bi-check-circle me-1"></i>
        {{ t('policies.my_all_done') }}
    </div>
    {% endif %}

    {% if acknowledged is not empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-body">
            <h2 class="h6 mb-0">{{ t('policies.my_acknowledged') }}</h2>
        </div>
        <ul class="list-group list-group-flush">
            {% for item in acknowledged %}
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <div class="fw-semibold">{{ item.policy_name }}</div>
                    <div class="small text-body-secondary">
                        {{ item.version_title }} <code>{{ item.version_number }}</code>
                        · {{ t('policies.accepted_at') }}: {{ item.accepted_at|date('d M Y H:i') }}
                    </div>
                </div>
                <a href="/my/policies/versions/{{ item.version_id }}" class="btn btn-outline-secondary btn-sm">{{ t('common.view') }}</a>
            </li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}
</div>
{% endblock %}
