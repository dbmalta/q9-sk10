{% extends "layouts/member.html.twig" %}

{% block title %}{{ policy.name }} — {{ t('policies.my_title') }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="mb-3">
        <a href="/my/policies" class="small text-body-secondary"><i class="bi bi-arrow-left me-1"></i>{{ t('common.back') }}</a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h1 class="h3 mb-1">{{ policy.name }}</h1>
            <div class="small text-body-secondary mb-3">
                {{ version.title }} · <code>{{ version.version_number }}</code>
            </div>
            <hr>
            <div class="policy-content">{{ version.content|raw }}</div>
        </div>
    </div>

    {% if already_accepted %}
    <div class="alert alert-success border-0 shadow-sm">
        <i class="bi bi-check-circle me-1"></i>
        {{ t('policies.already_accepted') }}
    </div>
    {% else %}
    <form method="POST" action="/my/policies/versions/{{ version.id }}/accept" class="card border-0 shadow-sm">
        <div class="card-body">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            <div class="form-check mb-3">
                <input type="checkbox" class="form-check-input" id="confirm" name="confirm" required>
                <label class="form-check-label" for="confirm">{{ t('policies.confirm_read') }}</label>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>{{ t('policies.accept_button') }}
            </button>
        </div>
    </form>
    {% endif %}
</div>
{% endblock %}
