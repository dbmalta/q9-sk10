{% extends "layouts/admin.html.twig" %}

{% block title %}{{ policy ? t('common.edit') : t('policies.create') }} — {{ t('nav.terms') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ policy ? t('common.edit') : t('policies.create') }}</h1>
</div>

<form method="POST" action="{{ policy ? '/admin/terms/policies/' ~ policy.id : '/admin/terms/policies' }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token }}">

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="mb-3">
                <label for="name" class="form-label">{{ t('policies.name') }} <span class="text-danger">*</span></label>
                <input type="text" name="name" id="name" class="form-control" required
                       value="{{ policy ? policy.name : '' }}">
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">{{ t('policies.description') }}</label>
                <textarea name="description" id="description" class="form-control" rows="2">{{ policy ? policy.description : '' }}</textarea>
            </div>

            <div class="mb-3" x-data="{ mode: '{{ scope is empty ? 'all' : 'selected' }}' }">
                <label class="form-label">{{ t('policies.audience') }}</label>
                <div class="small text-body-secondary mb-2">{{ t('policies.audience_help') }}</div>

                <div class="btn-group mb-2" role="group">
                    <input type="radio" class="btn-check" name="audience_mode" value="all" id="audience-all" x-model="mode">
                    <label class="btn btn-outline-primary btn-sm" for="audience-all">{{ t('policies.audience_all') }}</label>
                    <input type="radio" class="btn-check" name="audience_mode" value="selected" id="audience-selected" x-model="mode">
                    <label class="btn btn-outline-primary btn-sm" for="audience-selected">{{ t('policies.audience_selected') }}</label>
                </div>

                <div x-show="mode === 'selected'" x-data="nodeMultiSelect({{ nodes|json_encode|e('html_attr') }}, {{ scope|json_encode|e('html_attr') }})" @click.outside="open = false">
                    <div class="form-control d-flex flex-wrap gap-1 align-items-center" style="min-height: 2.5rem; cursor: text;" @click="openDropdown()">
                        <template x-for="id in selected" :key="id">
                            <span class="badge text-bg-primary d-inline-flex align-items-center">
                                <span x-text="labelFor(id)"></span>
                                <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.6rem;"
                                        @click.stop="toggle(id)" aria-label="remove"></button>
                            </span>
                        </template>
                        <input type="text" class="border-0 flex-grow-1" style="outline: none; background: transparent; min-width: 8rem;"
                               x-model="search"
                               @focus="open = true"
                               :placeholder="selected.length === 0 ? '{{ t('email.node_picker_placeholder') }}' : ''">
                    </div>

                    <template x-for="id in selected" :key="'hidden-' + id">
                        <input type="hidden" name="node_ids[]" :value="id">
                    </template>

                    <div class="card shadow-sm mt-1 position-absolute" style="z-index: 1050; max-height: 18rem; overflow-y: auto; width: calc(100% - 3rem);"
                         x-show="open && filtered().length > 0" x-cloak>
                        <ul class="list-group list-group-flush">
                            <template x-for="node in filtered()" :key="node.id">
                                <li class="list-group-item list-group-item-action d-flex align-items-center gap-2"
                                    style="cursor: pointer;"
                                    :class="{ 'active': selected.includes(node.id) }"
                                    @click.stop="toggle(node.id)">
                                    <input type="checkbox" class="form-check-input m-0" :checked="selected.includes(node.id)" tabindex="-1" readonly>
                                    <span :style="'padding-left: ' + (node.level * 1.25) + 'rem;'" x-text="node.name"></span>
                                </li>
                            </template>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">{{ t('common.save') }}</button>
    <a href="/admin/terms{{ policy ? '/policies/' ~ policy.id : '' }}" class="btn btn-outline-secondary ms-2">{{ t('common.cancel') }}</a>
</form>

<script>
function nodeMultiSelect(treeNodes, preselected) {
    const flat = [];
    (function walk(items, level) {
        for (const n of items) {
            flat.push({ id: n.id, name: n.name, level });
            if (n.children && n.children.length) walk(n.children, level + 1);
        }
    })(treeNodes, 0);
    return {
        allNodes: flat,
        selected: (preselected || []).map(Number),
        search: '',
        open: false,
        openDropdown() { this.open = true; },
        toggle(id) {
            const i = this.selected.indexOf(id);
            if (i === -1) this.selected.push(id); else this.selected.splice(i, 1);
        },
        labelFor(id) {
            const n = this.allNodes.find(x => x.id === id);
            return n ? n.name : '';
        },
        filtered() {
            const q = this.search.trim().toLowerCase();
            if (!q) return this.allNodes;
            return this.allNodes.filter(n => n.name.toLowerCase().includes(q));
        }
    };
}
</script>

<style>[x-cloak] { display: none !important; }</style>
{% endblock %}
