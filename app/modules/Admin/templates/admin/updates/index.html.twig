{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.updates') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('update.title') }}</h1>
</div>

<div class="row g-4">
    {# Current version card #}
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-body-secondary small mb-1">{{ t('update.current_version') }}</div>
                <div class="fs-3 fw-semibold font-monospace">v{{ current_version }}</div>
            </div>
        </div>
    </div>

    {# Check for updates card #}
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h2 class="h6 mb-0">{{ t('update.check_heading') }}</h2>
                    <button class="btn btn-sm btn-outline-primary"
                            hx-get="/admin/updates/check"
                            hx-target="#update-check-result"
                            hx-swap="innerHTML"
                            hx-indicator="#check-spinner">
                        <span id="check-spinner" class="htmx-indicator spinner-border spinner-border-sm me-1" role="status"></span>
                        <i class="bi bi-search me-1"></i>{{ t('update.check_now') }}
                    </button>
                </div>
                <div id="update-check-result">
                    <p class="text-body-secondary small mb-0">{{ t('update.check_prompt') }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Cache maintenance #}
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h2 class="h6 mb-1">{{ t('update.cache_heading') }}</h2>
                    <p class="text-body-secondary small mb-0">{{ t('update.cache_hint') }}</p>
                </div>
                <form method="POST" action="/admin/updates/clear-cache" class="mb-0">
                    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-trash3 me-1"></i>{{ t('update.clear_cache_button') }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
