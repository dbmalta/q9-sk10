{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('user.menu.account') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('user.menu.account') }}</h1>
</div>

<div class="card border-0 shadow-sm" style="max-width: 540px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-body-secondary">{{ t('auth.email') }}</dt>
            <dd class="col-sm-8 mb-0">{{ email }}</dd>
        </dl>

        <hr>

        <p class="text-body-secondary small mb-3">
            {{ t('user.account.no_member_linked')|default('This user account is not linked to a member record.') }}
        </p>

        <a href="/logout" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-box-arrow-right me-1"></i>{{ t('user.menu.logout') }}
        </a>
    </div>
</div>
{% endblock %}
