{% extends "layouts/auth.html.twig" %}

{% block title %}{{ t('auth.forgot_password') }}{% endblock %}

{% block body %}
    <h2 class="h5 fw-semibold mb-2">{{ t('auth.forgot_password_title') }}</h2>
    <p class="text-body-secondary small mb-3">{{ t('auth.forgot_password_help') }}</p>

    <form method="post" action="/forgot-password" novalidate>
        {{ csrf_field() }}

        <div class="mb-3">
            <label for="email" class="form-label">{{ t('auth.email') }}</label>
            <input
                type="email"
                id="email"
                name="email"
                class="form-control"
                autocomplete="email"
                autofocus
                required
            >
        </div>

        <div class="d-grid mb-3">
            <button type="submit" class="btn btn-primary">
                {{ t('auth.send_reset_link') }}
            </button>
        </div>

        <div class="text-center">
            <a href="/login" class="small text-body-secondary">
                {{ t('auth.back_to_login') }}
            </a>
        </div>
    </form>
{% endblock %}
