{% extends "layouts/auth.html.twig" %}

{% block title %}{{ t('auth.login') }}{% endblock %}

{% block body %}
    <h2 class="h5 fw-semibold mb-3">{{ t('auth.login') }}</h2>

    <form method="post" action="/login" novalidate>
        {{ csrf_field() }}

        <div class="mb-3">
            <label for="email" class="form-label">{{ t('auth.email') }}</label>
            <input
                type="email"
                id="email"
                name="email"
                class="form-control"
                value="{{ email|default('') }}"
                autocomplete="email"
                autofocus
                required
            >
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">{{ t('auth.password') }}</label>
            <input
                type="password"
                id="password"
                name="password"
                class="form-control"
                autocomplete="current-password"
                required
            >
        </div>

        <div class="d-grid mb-3">
            <button type="submit" class="btn btn-primary">
                {{ t('auth.login') }}
            </button>
        </div>

        <div class="text-center">
            <a href="/forgot-password" class="small text-body-secondary">
                {{ t('auth.forgot_password') }}
            </a>
        </div>
    </form>
{% endblock %}
