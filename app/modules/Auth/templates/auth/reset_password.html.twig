{% extends "layouts/auth.html.twig" %}

{% block title %}{{ t('auth.reset_password') }}{% endblock %}

{% block body %}
    <h2 class="h5 fw-semibold mb-2">{{ t('auth.reset_password') }}</h2>
    <p class="text-body-secondary small mb-3">{{ t('auth.reset_password_help', {email: email}) }}</p>

    <form method="post" action="/reset-password/{{ token }}" novalidate>
        {{ csrf_field() }}

        <div class="mb-3">
            <label for="password" class="form-label">{{ t('auth.new_password') }}</label>
            <input
                type="password"
                id="password"
                name="password"
                class="form-control"
                autocomplete="new-password"
                minlength="10"
                autofocus
                required
            >
            <div class="form-text">{{ t('auth.password_requirements', {min: '10'}) }}</div>
        </div>

        <div class="mb-3">
            <label for="password_confirm" class="form-label">{{ t('auth.confirm_password') }}</label>
            <input
                type="password"
                id="password_confirm"
                name="password_confirm"
                class="form-control"
                autocomplete="new-password"
                required
            >
        </div>

        <div class="d-grid mb-3">
            <button type="submit" class="btn btn-primary">
                {{ t('auth.reset_password') }}
            </button>
        </div>

        <div class="text-center">
            <a href="/login" class="small text-body-secondary">
                {{ t('auth.back_to_login') }}
            </a>
        </div>
    </form>
{% endblock %}
