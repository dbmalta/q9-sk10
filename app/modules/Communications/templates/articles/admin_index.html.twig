{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('articles.manage') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('articles.manage') }}</h1>
    <div class="d-flex gap-2">
        <a href="/admin/email" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-envelope me-1"></i>{{ t('email.compose') }}
        </a>
        <a href="/admin/articles/create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>{{ t('articles.create') }}
        </a>
    </div>
</div>

{% if articles is empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-newspaper text-body-secondary" style="font-size: 2.5rem;"></i>
            <p class="mt-3 text-body-secondary">{{ t('articles.no_articles') }}</p>
            <a href="/admin/articles/create" class="btn btn-primary btn-sm">{{ t('articles.create') }}</a>
        </div>
    </div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('articles.article_title') }}</th>
                    <th>{{ t('articles.visibility') }}</th>
                    <th>{{ t('common.status') }}</th>
                    <th>{{ t('common.created') }}</th>
                    <th class="text-end pe-3">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for article in articles %}
                <tr>
                    <td class="ps-3">
                        <strong>{{ article.title }}</strong>
                        <div class="text-body-secondary small">{{ article.author_email|default('—') }}</div>
                    </td>
                    <td>
                        <span class="badge bg-{{ article.visibility == 'public' ? 'success' : (article.visibility == 'portal' ? 'info' : 'secondary') }}">
                            {{ article.visibility }}
                        </span>
                    </td>
                    <td>
                        {% if article.is_published %}
                            <span class="badge bg-success">{{ t('articles.published') }}</span>
                        {% else %}
                            <span class="badge bg-warning">{{ t('articles.draft') }}</span>
                        {% endif %}
                    </td>
                    <td class="small">{{ article.created_at|date('d M Y') }}</td>
                    <td class="text-end pe-3">
                        <a href="/admin/articles/{{ article.id }}/edit" class="btn btn-sm btn-outline-secondary" title="{{ t('common.edit') }}">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% if article.is_published %}
                        <form method="POST" action="/admin/articles/{{ article.id }}/unpublish" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-warning" title="{{ t('articles.unpublish') }}">
                                <i class="bi bi-eye-slash"></i>
                            </button>
                        </form>
                        {% else %}
                        <form method="POST" action="/admin/articles/{{ article.id }}/publish" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-success" title="{{ t('articles.publish') }}">
                                <i class="bi bi-eye"></i>
                            </button>
                        </form>
                        {% endif %}
                        <form method="POST" action="/admin/articles/{{ article.id }}/delete" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="{{ t('common.delete') }}"
                                    onclick="return confirm('{{ t('common.confirm_delete') }}')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
