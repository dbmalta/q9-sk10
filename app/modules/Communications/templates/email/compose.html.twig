{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('email.compose') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('email.compose') }}</h1>
    <a href="/admin/email/log" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-list-ul me-1"></i>{{ t('email.log') }}
        {% if queue_stats.pending > 0 %}
        <span class="badge bg-warning ms-1">{{ queue_stats.pending }}</span>
        {% endif %}
    </a>
</div>

<form method="POST" action="/admin/email/send">
    <input type="hidden" name="_csrf" value="{{ csrf_token }}">

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="mb-3" x-data="{ mode: 'me' }">
                <label class="form-label">{{ t('email.recipients') }}</label>
                <div class="small text-body-secondary mb-2">{{ t('email.recipients_help') }}</div>

                <div class="btn-group mb-2" role="group">
                    <input type="radio" class="btn-check" name="recipients_mode" value="me" id="recipients-me" x-model="mode" checked>
                    <label class="btn btn-outline-primary btn-sm" for="recipients-me">{{ t('email.recipients_me') }}</label>
                    <input type="radio" class="btn-check" name="recipients_mode" value="all" id="recipients-all" x-model="mode">
                    <label class="btn btn-outline-primary btn-sm" for="recipients-all">{{ t('email.recipients_all') }}</label>
                    <input type="radio" class="btn-check" name="recipients_mode" value="selected" id="recipients-selected" x-model="mode">
                    <label class="btn btn-outline-primary btn-sm" for="recipients-selected">{{ t('email.recipients_selected') }}</label>
                </div>

                <div x-show="mode === 'selected'" x-data="nodeMultiSelect({{ nodes|json_encode|e('html_attr') }})" @click.outside="open = false">
                    <div class="form-control d-flex flex-wrap gap-1 align-items-center" style="min-height: 2.5rem; cursor: text;" @click="openDropdown()">
                        <template x-for="id in selected" :key="id">
                            <span class="badge text-bg-primary d-inline-flex align-items-center">
                                <span x-text="labelFor(id)"></span>
                                <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.6rem;"
                                        @click.stop="toggle(id)" :aria-label="'{{ t('common.remove') }}'"></button>
                            </span>
                        </template>
                        <input type="text" class="border-0 flex-grow-1" style="outline: none; background: transparent; min-width: 8rem;"
                               x-model="search"
                               @focus="open = true"
                               :placeholder="selected.length === 0 ? '{{ t('email.node_picker_placeholder') }}' : ''">
                    </div>

                    <template x-for="id in selected" :key="'hidden-' + id">
                        <input type="hidden" name="node_ids[]" :value="id">
                    </template>

                    <div class="card shadow-sm mt-1 position-absolute" style="z-index: 1050; max-height: 18rem; overflow-y: auto; width: calc(100% - 3rem);"
                         x-show="open && filtered().length > 0" x-cloak>
                        <ul class="list-group list-group-flush">
                            <template x-for="node in filtered()" :key="node.id">
                                <li class="list-group-item list-group-item-action d-flex align-items-center gap-2"
                                    style="cursor: pointer;"
                                    :class="{ 'active': selected.includes(node.id) }"
                                    @click.stop="toggle(node.id)">
                                    <input type="checkbox" class="form-check-input m-0" :checked="selected.includes(node.id)" tabindex="-1" readonly>
                                    <span :style="'padding-left: ' + (node.level * 1.25) + 'rem;'" x-text="node.name"></span>
                                </li>
                            </template>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label for="subject" class="form-label">{{ t('email.subject') }} <span class="text-danger">*</span></label>
                <input type="text" name="subject" id="subject" class="form-control" required>
            </div>

            <div class="mb-3">
                <label for="body" class="form-label">{{ t('email.body') }} <span class="text-danger">*</span></label>
                <textarea name="body" id="body" class="form-control" rows="10" data-wysiwyg required></textarea>
                <div class="form-text">{{ t('email.html_allowed') }}</div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary" onclick="return confirm('{{ t('email.confirm_send') }}')">
        <i class="bi bi-send me-1"></i>{{ t('email.send') }}
    </button>
    <a href="/admin/articles" class="btn btn-outline-secondary ms-2">{{ t('common.cancel') }}</a>
</form>

<script>
function nodeMultiSelect(treeNodes) {
    // Flatten tree into [{id, name, level}] in DFS order so indentation reflects hierarchy
    const flat = [];
    (function walk(items, level) {
        for (const n of items) {
            flat.push({ id: n.id, name: n.name, level });
            if (n.children && n.children.length) walk(n.children, level + 1);
        }
    })(treeNodes, 0);
    return {
        allNodes: flat,
        selected: [],
        search: '',
        open: false,
        openDropdown() { this.open = true; },
        toggle(id) {
            const i = this.selected.indexOf(id);
            if (i === -1) this.selected.push(id); else this.selected.splice(i, 1);
        },
        labelFor(id) {
            const n = this.allNodes.find(x => x.id === id);
            return n ? n.name : '';
        },
        filtered() {
            const q = this.search.trim().toLowerCase();
            if (!q) return this.allNodes;
            return this.allNodes.filter(n => n.name.toLowerCase().includes(q));
        }
    };
}
</script>

<style>[x-cloak] { display: none !important; }</style>
{% endblock %}
