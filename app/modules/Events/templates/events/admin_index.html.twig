{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('events.manage') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('events.manage') }}</h1>
    <a href="/admin/events/create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>{{ t('events.create') }}
    </a>
</div>

{% set month_names = {
    1:'months.january', 2:'months.february', 3:'months.march', 4:'months.april',
    5:'months.may', 6:'months.june', 7:'months.july', 8:'months.august',
    9:'months.september', 10:'months.october', 11:'months.november', 12:'months.december'
} %}

<form method="GET" action="/admin/events" class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-auto">
                <label class="col-form-label-sm text-body-secondary mb-0">{{ t('events.filter_by_date') }}</label>
            </div>
            <div class="col-auto">
                <select name="year" class="form-select form-select-sm">
                    <option value="">{{ t('events.all_years') }}</option>
                    {% for y in available_years %}
                    <option value="{{ y }}" {{ filter_year == y ? 'selected' : '' }}>{{ y }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-auto">
                <select name="month" class="form-select form-select-sm">
                    <option value="">{{ t('events.all_months') }}</option>
                    {% for m, key in month_names %}
                    <option value="{{ m }}" {{ filter_month == m ? 'selected' : '' }}>{{ t(key) }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">{{ t('common.filter') }}</button>
                {% if filter_year or filter_month %}
                <a href="/admin/events" class="btn btn-sm btn-outline-secondary">{{ t('common.clear') }}</a>
                {% endif %}
            </div>
        </div>
    </div>
</form>

{% if events is empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-calendar-event text-body-secondary" style="font-size: 2.5rem;"></i>
            <p class="mt-3 text-body-secondary">{{ t('events.no_events') }}</p>
            <a href="/admin/events/create" class="btn btn-primary btn-sm">{{ t('events.create') }}</a>
        </div>
    </div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('events.event_title') }}</th>
                    <th>{{ t('events.date') }}</th>
                    <th>{{ t('common.status') }}</th>
                    <th>{{ t('common.created') }}</th>
                    <th class="text-end pe-3">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for event in events %}
                <tr>
                    <td class="ps-3">
                        <strong>{{ event.title }}</strong>
                        {% if event.location %}
                        <div class="text-body-secondary small">
                            <i class="bi bi-geo-alt"></i> {{ event.location }}
                        </div>
                        {% endif %}
                    </td>
                    <td>
                        {% if event.all_day %}
                            {{ event.start_date|date('d M Y') }}
                            <span class="badge bg-info ms-1">{{ t('events.all_day') }}</span>
                        {% else %}
                            {{ event.start_date|date('d M Y H:i') }}
                        {% endif %}
                    </td>
                    <td>
                        {% if event.is_published %}
                            <span class="badge text-bg-success"><i class="bi bi-check-circle-fill me-1"></i>{{ t('events.published') }}</span>
                        {% else %}
                            <span class="badge text-bg-warning"><i class="bi bi-pencil-fill me-1"></i>{{ t('events.draft') }}</span>
                        {% endif %}
                    </td>
                    <td class="small">{{ event.created_at|date('d M Y') }}</td>
                    <td class="text-end pe-3">
                        <a href="/admin/events/{{ event.id }}/edit" class="btn btn-sm btn-outline-secondary" title="{{ t('common.edit') }}">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% if event.is_published %}
                        <form method="POST" action="/admin/events/{{ event.id }}/unpublish" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-warning" title="{{ t('events.unpublish') }}">
                                <i class="bi bi-eye-slash-fill"></i>
                            </button>
                        </form>
                        {% else %}
                        <form method="POST" action="/admin/events/{{ event.id }}/publish" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-success" title="{{ t('events.publish') }}">
                                <i class="bi bi-eye-fill"></i>
                            </button>
                        </form>
                        {% endif %}
                        <form method="POST" action="/admin/events/{{ event.id }}/delete" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="{{ t('common.delete') }}"
                                    onclick="return confirm('{{ t('common.confirm_delete') }}')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% if pagination.pages > 1 %}
<nav class="d-flex justify-content-center mt-4">
    <ul class="pagination pagination-sm">
        {% if pagination.page > 1 %}
        <li class="page-item"><a class="page-link" href="/admin/events?{% if filter_year %}year={{ filter_year }}&{% endif %}{% if filter_month %}month={{ filter_month }}&{% endif %}page={{ pagination.page - 1 }}">{{ t('pagination.previous') }}</a></li>
        {% endif %}
        {% for p in range(max(1, pagination.page - 2), min(pagination.pages, pagination.page + 2)) %}
        <li class="page-item {{ p == pagination.page ? 'active' : '' }}"><a class="page-link" href="/admin/events?{% if filter_year %}year={{ filter_year }}&{% endif %}{% if filter_month %}month={{ filter_month }}&{% endif %}page={{ p }}">{{ p }}</a></li>
        {% endfor %}
        {% if pagination.page < pagination.pages %}
        <li class="page-item"><a class="page-link" href="/admin/events?{% if filter_year %}year={{ filter_year }}&{% endif %}{% if filter_month %}month={{ filter_month }}&{% endif %}page={{ pagination.page + 1 }}">{{ t('pagination.next') }}</a></li>
        {% endif %}
    </ul>
</nav>
{% endif %}
{% endif %}
{% endblock %}
