{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('events.manage') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('events.manage') }}</h1>
    <a href="/admin/events/create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>{{ t('events.create') }}
    </a>
</div>

{% if events is empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-calendar-event text-body-secondary" style="font-size: 2.5rem;"></i>
            <p class="mt-3 text-body-secondary">{{ t('events.no_events') }}</p>
            <a href="/admin/events/create" class="btn btn-primary btn-sm">{{ t('events.create') }}</a>
        </div>
    </div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('events.event_title') }}</th>
                    <th>{{ t('events.date') }}</th>
                    <th>{{ t('common.status') }}</th>
                    <th>{{ t('common.created') }}</th>
                    <th class="text-end pe-3">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for event in events %}
                <tr>
                    <td class="ps-3">
                        <strong>{{ event.title }}</strong>
                        {% if event.location %}
                        <div class="text-body-secondary small">
                            <i class="bi bi-geo-alt"></i> {{ event.location }}
                        </div>
                        {% endif %}
                    </td>
                    <td>
                        {% if event.all_day %}
                            {{ event.start_date|date('d M Y') }}
                            <span class="badge bg-info ms-1">{{ t('events.all_day') }}</span>
                        {% else %}
                            {{ event.start_date|date('d M Y H:i') }}
                        {% endif %}
                    </td>
                    <td>
                        {% if event.is_published %}
                            <span class="badge bg-success">{{ t('events.published') }}</span>
                        {% else %}
                            <span class="badge bg-warning">{{ t('events.draft') }}</span>
                        {% endif %}
                    </td>
                    <td class="small">{{ event.created_at|date('d M Y') }}</td>
                    <td class="text-end pe-3">
                        <a href="/admin/events/{{ event.id }}/edit" class="btn btn-sm btn-outline-secondary" title="{{ t('common.edit') }}">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% if event.is_published %}
                        <form method="POST" action="/admin/events/{{ event.id }}/unpublish" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-warning" title="{{ t('events.unpublish') }}">
                                <i class="bi bi-eye-slash"></i>
                            </button>
                        </form>
                        {% else %}
                        <form method="POST" action="/admin/events/{{ event.id }}/publish" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-success" title="{{ t('events.publish') }}">
                                <i class="bi bi-eye"></i>
                            </button>
                        </form>
                        {% endif %}
                        <form method="POST" action="/admin/events/{{ event.id }}/delete" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="{{ t('common.delete') }}"
                                    onclick="return confirm('{{ t('common.confirm_delete') }}')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% if pagination.pages > 1 %}
<nav class="d-flex justify-content-center mt-4">
    <ul class="pagination pagination-sm">
        {% if pagination.page > 1 %}
        <li class="page-item"><a class="page-link" href="/admin/events?page={{ pagination.page - 1 }}">{{ t('pagination.previous') }}</a></li>
        {% endif %}
        {% for p in range(max(1, pagination.page - 2), min(pagination.pages, pagination.page + 2)) %}
        <li class="page-item {{ p == pagination.page ? 'active' : '' }}"><a class="page-link" href="/admin/events?page={{ p }}">{{ p }}</a></li>
        {% endfor %}
        {% if pagination.page < pagination.pages %}
        <li class="page-item"><a class="page-link" href="/admin/events?page={{ pagination.page + 1 }}">{{ t('pagination.next') }}</a></li>
        {% endif %}
    </ul>
</nav>
{% endif %}
{% endif %}
{% endblock %}
