{% extends "layouts/admin.html.twig" %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
<article class="mb-4">
    <div class="mb-4">
        <h1 class="h3">{{ event.title }}</h1>
        <div class="text-body-secondary small">
            {% if event.all_day %}
                {{ event.start_date|date('d M Y') }}
                {% if event.end_date %}
                    &ndash; {{ event.end_date|date('d M Y') }}
                {% endif %}
                <span class="badge bg-info ms-2">{{ t('events.all_day') }}</span>
            {% else %}
                {{ event.start_date|date('d M Y H:i') }}
                {% if event.end_date %}
                    &ndash; {{ event.end_date|date('d M Y H:i') }}
                {% endif %}
            {% endif %}
            {% if event.node_scope_id %}
                <span class="badge bg-secondary ms-2">{{ t('events.scoped') }}</span>
            {% else %}
                <span class="badge bg-success ms-2">{{ t('events.global') }}</span>
            {% endif %}
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            {% if event.location %}
            <div class="mb-3">
                <i class="bi bi-geo-alt text-body-secondary me-1"></i>
                <strong>{{ t('events.location') }}:</strong> {{ event.location }}
            </div>
            {% endif %}

            {% if event.description %}
            <div class="mt-3">
                {{ event.description|nl2br }}
            </div>
            {% else %}
            <p class="text-body-secondary mb-0">{{ t('events.no_description') }}</p>
            {% endif %}
        </div>
    </div>
</article>

<div class="d-flex gap-2">
    <a href="/events" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>{{ t('common.back') }}
    </a>
    {% if has_permission('events.write') %}
    <a href="/admin/events/{{ event.id }}/edit" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-pencil me-1"></i>{{ t('common.edit') }}
    </a>
    {% endif %}
</div>
{% endblock %}
