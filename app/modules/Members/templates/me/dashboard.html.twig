{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('me.dashboard.title') }}{% endblock %}

{% block body %}
<div class="mb-4">
    <h1 class="h3 mb-1">{{ t('me.welcome', {name: member.first_name}) }}</h1>
    <p class="text-body-secondary mb-0">
        {% if nodes|length > 0 %}
            {{ t('me.member_of') }}
            {% for n in nodes %}<span class="badge bg-secondary-subtle text-secondary-emphasis me-1">{{ n.name }}</span>{% endfor %}
        {% else %}
            {{ t('me.no_nodes') }}
        {% endif %}
    </p>
</div>

<div class="row g-4">
    {# Notices column — show only if there are notices #}
    {% if notices|length > 0 %}
    <div class="col-12">
        <div class="card border-warning shadow-sm">
            <div class="card-header bg-warning-subtle">
                <h5 class="mb-0"><i class="bi bi-megaphone me-2"></i>{{ t('me.notices_heading') }}</h5>
            </div>
            <ul class="list-group list-group-flush">
                {% for notice in notices %}
                <li class="list-group-item">
                    <div class="fw-medium">{{ notice.title }}</div>
                    {% if notice.content %}<div class="small text-body-secondary">{{ notice.content|striptags|slice(0, 200) }}</div>{% endif %}
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>
    {% endif %}

    {# Upcoming events #}
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom d-flex align-items-center justify-content-between">
                <h5 class="mb-0"><i class="bi bi-calendar-event me-2"></i>{{ t('me.upcoming_events') }}</h5>
                <a href="/events" class="small text-decoration-none">{{ t('common.view_all') }}</a>
            </div>
            {% if upcoming_events|length == 0 %}
                <div class="card-body text-body-secondary small">{{ t('me.no_upcoming_events') }}</div>
            {% else %}
                <ul class="list-group list-group-flush">
                    {% for e in upcoming_events %}
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="fw-medium">{{ e.title }}</div>
                                <div class="small text-body-secondary">
                                    <i class="bi bi-clock me-1"></i>{{ e.start_date|date('D d M, H:i') }}
                                    {% if e.location %}· <i class="bi bi-geo-alt ms-1 me-1"></i>{{ e.location }}{% endif %}
                                </div>
                            </div>
                        </div>
                    </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    </div>

    {# Recent articles #}
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom d-flex align-items-center justify-content-between">
                <h5 class="mb-0"><i class="bi bi-newspaper me-2"></i>{{ t('me.recent_articles') }}</h5>
                <a href="/articles" class="small text-decoration-none">{{ t('common.view_all') }}</a>
            </div>
            {% if recent_articles|length == 0 %}
                <div class="card-body text-body-secondary small">{{ t('me.no_articles') }}</div>
            {% else %}
                <ul class="list-group list-group-flush">
                    {% for a in recent_articles %}
                    <li class="list-group-item">
                        <div class="fw-medium">
                            {% if a.slug %}<a href="/articles/{{ a.slug }}" class="text-decoration-none">{{ a.title }}</a>
                            {% else %}{{ a.title }}{% endif %}
                        </div>
                        <div class="small text-body-secondary">
                            {{ a.published_at ? a.published_at|date('d M Y') : '' }}
                        </div>
                    </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    </div>

    {# Profile actions #}
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex flex-wrap gap-2 align-items-center justify-content-between">
                <div>
                    <div class="fw-medium">{{ member.first_name }} {{ member.surname }}</div>
                    <div class="small text-body-secondary">
                        {{ t('me.membership_number') }}: {{ member.membership_number }}
                        · <span class="badge bg-success-subtle text-success-emphasis">{{ member.status }}</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <a href="/members/{{ member.id }}" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-person me-1"></i>{{ t('nav.view_profile') }}
                    </a>
                    <a href="/me/profile/edit" class="btn btn-primary btn-sm">
                        <i class="bi bi-pencil-square me-1"></i>{{ t('nav.edit_profile') }}
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
