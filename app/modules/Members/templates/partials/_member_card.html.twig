{# HTMX member card partial. Expects: member #}
<div class="card border-0 shadow-sm">
    <div class="card-body p-3">
        <div class="d-flex align-items-center mb-2">
            <div class="avatar-circle bg-primary-subtle text-primary me-2" style="width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.9rem;font-weight:600;">
                {{ member.first_name|first|upper }}{{ member.surname|first|upper }}
            </div>
            <div>
                <a href="/members/{{ member.id }}" class="fw-medium text-decoration-none">
                    {{ member.first_name }} {{ member.surname }}
                </a>
                <div class="small text-body-secondary">{{ member.membership_number }}</div>
            </div>
            <div class="ms-auto">
                {% include "@members/partials/_status_badge.html.twig" with { member: member } %}
            </div>
        </div>
        {% if member.email %}
        <div class="small"><i class="bi bi-envelope me-1 text-body-secondary"></i>{{ member.email }}</div>
        {% endif %}
        {% if member.phone %}
        <div class="small"><i class="bi bi-telephone me-1 text-body-secondary"></i>{{ member.phone }}</div>
        {% endif %}
    </div>
</div>
