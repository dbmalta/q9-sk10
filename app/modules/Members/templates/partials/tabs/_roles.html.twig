{# Role history tab. Expects: member, assignments, can_write_roles #}
{% if member.user_id %}
    {% if can_write_roles %}
    <div class="d-flex justify-content-end mb-3">
        <a href="/admin/roles/assignments/{{ member.user_id }}" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-shield-plus me-1"></i>{{ t('members.manage_roles') }}
        </a>
    </div>
    {% endif %}
    {% if assignments is not empty %}
    <div class="list-group list-group-flush">
        {% for a in assignments %}
        <div class="list-group-item px-0 {{ a.is_active ? '' : 'opacity-50' }}">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <span class="fw-medium">{{ a.role_name }}</span>
                    {% if a.context_name is defined and a.context_name %}
                    <span class="text-body-secondary small ms-1">&middot; {{ a.context_name }}</span>
                    {% endif %}
                </div>
                {% if a.is_active %}
                <span class="badge bg-success-subtle text-success">{{ t('permissions.active') }}</span>
                {% else %}
                <span class="badge bg-secondary-subtle text-secondary">{{ t('permissions.ended') }}</span>
                {% endif %}
            </div>
            <div class="small text-body-secondary mt-1">
                {{ a.start_date }}
                {% if a.end_date %} &mdash; {{ a.end_date }}{% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <p class="text-body-secondary">{{ t('permissions.no_assignments') }}</p>
    {% endif %}
{% else %}
    {% if can_write_roles %}
    <div class="alert alert-info border-0 mb-3">
        <i class="bi bi-info-circle me-1"></i>{{ t('members.no_login_account') }}
    </div>
    <form method="POST" action="/members/{{ member.id }}/create-account">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <div class="mb-3">
            <label class="form-label small fw-medium">{{ t('auth.email') }}</label>
            <input type="email" name="email" class="form-control form-control-sm"
                   value="{{ member.email }}" required>
        </div>
        <div class="mb-3">
            <label class="form-label small fw-medium">{{ t('auth.password') }}</label>
            <input type="password" name="password" class="form-control form-control-sm"
                   minlength="8" required autocomplete="new-password">
            <div class="form-text">{{ t('auth.password_requirements', {min: 8}) }}</div>
        </div>
        <button type="submit" class="btn btn-sm btn-primary">
            <i class="bi bi-person-check me-1"></i>{{ t('members.create_login_account') }}
        </button>
    </form>
    {% else %}
    <p class="text-body-secondary">{{ t('members.no_login_account_readonly') }}</p>
    {% endif %}
{% endif %}
