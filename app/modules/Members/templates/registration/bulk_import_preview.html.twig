{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('registration.preview') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('registration.preview') }}</h1>
    <a href="/admin/bulk-import" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>{{ t('common.back') }}
    </a>
</div>

{# Summary #}
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="h2 mb-0 text-success">{{ valid|length }}</div>
                <small class="text-body-secondary">{{ t('registration.valid_rows') }}</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="h2 mb-0 text-danger">{{ errors|length }}</div>
                <small class="text-body-secondary">{{ t('registration.error_rows') }}</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="h2 mb-0">{{ valid|length + errors|length }}</div>
                <small class="text-body-secondary">{{ t('registration.total_rows') }}</small>
            </div>
        </div>
    </div>
</div>

{# Errors #}
{% if errors is not empty %}
<div class="card border-0 shadow-sm mb-4 border-danger">
    <div class="card-header bg-danger-subtle">
        <h6 class="mb-0 text-danger"><i class="bi bi-exclamation-triangle me-1"></i>{{ t('registration.rows_with_errors') }}</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3" style="width: 60px;">{{ t('registration.row') }}</th>
                    <th>{{ t('members.first_name') }}</th>
                    <th>{{ t('members.surname') }}</th>
                    <th>{{ t('members.email') }}</th>
                    <th>{{ t('registration.errors') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for err in errors %}
                <tr>
                    <td class="ps-3"><code>{{ err.row }}</code></td>
                    <td>{{ err.data.first_name|default('') }}</td>
                    <td>{{ err.data.surname|default('') }}</td>
                    <td>{{ err.data.email|default('') }}</td>
                    <td>
                        {% for e in err.errors %}
                        <div class="text-danger small"><i class="bi bi-x-circle me-1"></i>{{ e }}</div>
                        {% endfor %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{# Valid rows preview #}
{% if valid is not empty %}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success-subtle">
        <h6 class="mb-0 text-success"><i class="bi bi-check-circle me-1"></i>{{ t('registration.valid_rows') }}</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3" style="width: 60px;">{{ t('registration.row') }}</th>
                    <th>{{ t('members.first_name') }}</th>
                    <th>{{ t('members.surname') }}</th>
                    <th>{{ t('members.email') }}</th>
                    <th>{{ t('members.phone') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for v in valid %}
                <tr>
                    <td class="ps-3"><code>{{ v.row }}</code></td>
                    <td>{{ v.data.first_name|default('') }}</td>
                    <td>{{ v.data.surname|default('') }}</td>
                    <td>{{ v.data.email|default('') }}</td>
                    <td>{{ v.data.phone|default('') }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# Confirm import #}
<div class="text-end">
    <form method="POST" action="/admin/bulk-import/confirm" class="d-inline">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        <a href="/admin/bulk-import" class="btn btn-outline-secondary me-2">{{ t('common.cancel') }}</a>
        <button type="submit" class="btn btn-success">
            <i class="bi bi-check-lg me-1"></i>{{ t('registration.confirm_import', { count: valid|length }) }}
        </button>
    </form>
</div>
{% else %}
<div class="text-center py-4">
    <p class="text-body-secondary">{{ t('registration.no_valid_rows') }}</p>
    <a href="/admin/bulk-import" class="btn btn-outline-primary btn-sm">{{ t('common.try_again') }}</a>
</div>
{% endif %}
{% endblock %}
