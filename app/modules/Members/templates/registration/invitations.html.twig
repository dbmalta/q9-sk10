{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('registration.invitations') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('registration.invitations') }}</h1>
    <a href="/admin/registrations" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>{{ t('registration.pending') }}
    </a>
</div>

{# Create invitation form #}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <h6 class="card-title mb-3">{{ t('registration.create_invitation') }}</h6>
        <form method="POST" action="/admin/invitations" class="row g-2 align-items-end">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            <div class="col-md-4">
                <label for="inv-node" class="form-label small mb-1">{{ t('members.node') }}</label>
                <select name="node_id" id="inv-node" class="form-select form-select-sm" required>
                    <option value="">{{ t('common.select') }}...</option>
                    {{ _self.render_node_options(nodes, '') }}
                </select>
            </div>
            <div class="col-md-4">
                <label for="inv-email" class="form-label small mb-1">{{ t('registration.target_email') }} <span class="text-body-secondary">({{ t('common.optional') }})</span></label>
                <input type="email" name="email" id="inv-email" class="form-control form-control-sm" placeholder="name@example.com">
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-sm btn-primary w-100">
                    <i class="bi bi-plus-lg me-1"></i>{{ t('registration.create_invitation') }}
                </button>
            </div>
        </form>
    </div>
</div>

{# Filter by node #}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="GET" action="/admin/invitations" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label for="filter-node" class="form-label small mb-1">{{ t('registration.filter_by_node') }}</label>
                <select name="node_id" id="filter-node" class="form-select form-select-sm">
                    <option value="">{{ t('common.select') }}...</option>
                    {{ _self.render_node_options(nodes, '') }}
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="show_all" value="1" id="show-all" {{ show_all ? 'checked' : '' }}>
                    <label class="form-check-label small" for="show-all">{{ t('registration.show_expired_used') }}</label>
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="bi bi-funnel me-1"></i>{{ t('common.filter') }}
                </button>
            </div>
        </form>
    </div>
</div>

{% if selected_node_id == 0 %}
    <div class="text-center text-body-secondary py-4">
        <i class="bi bi-arrow-up-circle" style="font-size: 2rem;"></i>
        <p class="mt-2">{{ t('registration.select_node_to_view') }}</p>
    </div>
{% elseif invitations is empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-envelope-open text-body-secondary" style="font-size: 2.5rem;"></i>
            <p class="mt-3 text-body-secondary">{{ t('registration.no_invitations') }}</p>
        </div>
    </div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('registration.token') }}</th>
                    <th>{{ t('registration.target_email') }}</th>
                    <th>{{ t('registration.created_by') }}</th>
                    <th>{{ t('registration.expires_at') }}</th>
                    <th>{{ t('common.status') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for inv in invitations %}
                <tr>
                    <td class="ps-3">
                        <code class="small user-select-all">{{ inv.token[:16] }}...</code>
                    </td>
                    <td>{{ inv.email|default('—') }}</td>
                    <td>{{ inv.creator_email|default('—') }}</td>
                    <td>{{ inv.expires_at|date('d M Y H:i') }}</td>
                    <td>
                        {% if inv.used_at %}
                            <span class="badge bg-secondary">{{ t('registration.used') }}</span>
                        {% elseif inv.expires_at < "now"|date('Y-m-d H:i:s') %}
                            <span class="badge bg-danger">{{ t('registration.expired') }}</span>
                        {% else %}
                            <span class="badge bg-success">{{ t('registration.active') }}</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% macro render_node_options(nodes, prefix) %}
    {% for node in nodes %}
    <option value="{{ node.id }}">{{ prefix }}{{ node.name }}</option>
        {% if node.children is defined and node.children is not empty %}
            {{ _self.render_node_options(node.children, prefix ~ '  ') }}
        {% endif %}
    {% endfor %}
{% endmacro %}
{% endblock %}
