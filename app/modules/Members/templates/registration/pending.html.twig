{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('registration.pending') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ t('registration.pending') }}</h1>
    <div class="d-flex gap-2">
        <a href="/admin/invitations" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-envelope me-1"></i>{{ t('registration.invitations') }}
        </a>
        <a href="/admin/bulk-import" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-upload me-1"></i>{{ t('registration.bulk_import') }}
        </a>
        <a href="/admin/waiting-list" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-hourglass-split me-1"></i>{{ t('registration.waiting_list') }}
        </a>
    </div>
</div>

{% if registrations is empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-check-circle text-success" style="font-size: 2.5rem;"></i>
            <p class="mt-3 text-body-secondary">{{ t('registration.no_pending') }}</p>
        </div>
    </div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">{{ t('members.member') }}</th>
                    <th>{{ t('members.email') }}</th>
                    <th>{{ t('members.node') }}</th>
                    <th>{{ t('registration.registered_at') }}</th>
                    <th class="text-end pe-3">{{ t('common.actions') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for reg in registrations %}
                <tr>
                    <td class="ps-3">
                        <strong>{{ reg.first_name }} {{ reg.surname }}</strong>
                    </td>
                    <td>{{ reg.email|default('—') }}</td>
                    <td>{{ reg.node_ids|default('—') }}</td>
                    <td>{{ reg.created_at|date('d M Y H:i') }}</td>
                    <td class="text-end pe-3">
                        <form method="POST" action="/admin/registrations/{{ reg.id }}/approve" class="d-inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-success" title="{{ t('registration.approve') }}">
                                <i class="bi bi-check-lg"></i>
                            </button>
                        </form>
                        <button type="button" class="btn btn-sm btn-danger ms-1" title="{{ t('registration.reject') }}"
                                data-bs-toggle="modal" data-bs-target="#rejectModal{{ reg.id }}">
                            <i class="bi bi-x-lg"></i>
                        </button>

                        {# Reject modal #}
                        <div class="modal fade" id="rejectModal{{ reg.id }}" tabindex="-1">
                            <div class="modal-dialog modal-sm">
                                <form method="POST" action="/admin/registrations/{{ reg.id }}/reject" class="modal-content">
                                    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                                    <div class="modal-header">
                                        <h6 class="modal-title">{{ t('registration.reject') }}</h6>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <label for="reason-{{ reg.id }}" class="form-label small">{{ t('registration.rejection_reason') }}</label>
                                        <textarea name="reason" id="reason-{{ reg.id }}" class="form-control form-control-sm" rows="3"></textarea>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">{{ t('common.cancel') }}</button>
                                        <button type="submit" class="btn btn-sm btn-danger">{{ t('registration.reject') }}</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
