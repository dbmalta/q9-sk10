{% extends "layouts/admin.html.twig" %}

{% block title %}{{ t('nav.org_structure') }}{% endblock %}

{% block body %}
<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">{{ t('nav.org_structure') }}</h1>
        <div class="d-flex gap-2">
            {% if has_permission('org_structure.write') %}
            <a href="/admin/org/levels" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-sliders me-1"></i>{{ t('org.level_types') }}
            </a>
            <a href="/admin/org/nodes/create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>{{ t('org.add_node') }}
            </a>
            {% endif %}
        </div>
    </div>

    {% if tree is empty %}
        {% include "components/_empty_state.html.twig" with {
            icon: 'bi-diagram-3',
            message: t('org.no_nodes'),
            action_label: t('org.add_node'),
            action_url: '/admin/org/nodes/create'
        } %}
    {% else %}
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            {{ _self.render_tree(tree) }}
        </div>
    </div>
    {% endif %}
</div>

{% macro render_tree(nodes) %}
<ul class="list-unstyled mb-0">
    {% for node in nodes %}
    <li class="mb-1" x-data="{ open: true }">
        <div class="d-flex align-items-center py-1 px-2 rounded hover-bg">
            {% if node.children is not empty %}
            <button class="btn btn-sm btn-link p-0 me-1 text-body-secondary" @click="open = !open" style="width: 20px;">
                <i class="bi" :class="open ? 'bi-chevron-down' : 'bi-chevron-right'"></i>
            </button>
            {% else %}
            <span style="width: 20px; display: inline-block;" class="me-1"></span>
            {% endif %}

            <i class="bi {{ node.is_leaf ? 'bi-people' : 'bi-folder' }} text-body-secondary me-2"></i>

            <a href="/admin/org/nodes/{{ node.id }}" class="text-decoration-none fw-medium">
                {{ node.name }}
            </a>

            <span class="badge bg-light text-body-secondary ms-2 small">{{ node.level_type_name }}</span>

            {% if node.team_count > 0 %}
            <span class="badge bg-info-subtle text-info-emphasis ms-1" title="{{ t('org.teams') }}">
                <i class="bi bi-people-fill"></i> {{ node.team_count }}
            </span>
            {% endif %}

            {% if not node.is_active %}
            <span class="badge bg-warning-subtle text-warning-emphasis ms-1">{{ t('org.inactive') }}</span>
            {% endif %}
        </div>

        {% if node.children is not empty %}
        <div x-show="open" class="ms-4">
            {{ _self.render_tree(node.children) }}
        </div>
        {% endif %}
    </li>
    {% endfor %}
</ul>
{% endmacro %}
{% endblock %}

{% block head %}
<style>
    .hover-bg:hover { background-color: var(--bs-tertiary-bg); }
</style>
{% endblock %}
