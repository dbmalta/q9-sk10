{#
    Confirmation modal component
    Expects: modal_id, title, message, confirm_url, confirm_method (default POST), confirm_label (default Confirm)
#}
<div class="modal fade" id="{{ modal_id }}" tabindex="-1" aria-labelledby="{{ modal_id }}Label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="{{ modal_id }}Label">{{ title }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ t('common.close') }}"></button>
            </div>
            <div class="modal-body">
                <p>{{ message }}</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ t('common.cancel') }}</button>
                <form method="{{ confirm_method|default('POST') }}" action="{{ confirm_url }}">
                    {{ csrf_field() }}
                    <button type="submit" class="btn btn-danger">{{ confirm_label|default(t('common.confirm')) }}</button>
                </form>
            </div>
        </div>
    </div>
</div>
