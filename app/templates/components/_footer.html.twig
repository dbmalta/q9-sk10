{#
    Global footer. Sits at the bottom of every authenticated page to
    visually close the content and surface the product attribution.

    The bg-body-tertiary token is Bootstrap-managed and flips tone
    automatically for dark mode. A 1px top border reinforces the
    "end of page" signal without being visually heavy.
#}
<footer class="app-footer border-top bg-body-tertiary mt-auto">
    <div class="container-fluid px-4 py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="small text-body-secondary">
            <span class="fw-semibold text-body">ScoutKeeper</span>
            <span class="mx-2">·</span>
            <span>v{{ app_version|default('0.0.0') }}</span>
            <span class="mx-2">·</span>
            <a href="https://www.gnu.org/licenses/agpl-3.0.html"
               class="text-body-secondary text-decoration-none"
               target="_blank" rel="noopener noreferrer">AGPL&nbsp;v3</a>
        </div>
        <div class="small text-body-secondary d-flex align-items-center gap-2">
            <span>{{ t('footer.built_by') }}</span>
            <a href="https://quadnine.com"
               class="text-body text-decoration-none fw-medium d-inline-flex align-items-center"
               target="_blank" rel="noopener noreferrer"
               title="QuadNine Ltd">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="me-1" aria-hidden="true">
                    <rect x="3"  y="3"  width="7" height="7" rx="1.5" fill="currentColor" opacity="0.9"/>
                    <rect x="14" y="3"  width="7" height="7" rx="1.5" fill="currentColor" opacity="0.6"/>
                    <rect x="3"  y="14" width="7" height="7" rx="1.5" fill="currentColor" opacity="0.6"/>
                    <rect x="14" y="14" width="7" height="7" rx="1.5" fill="currentColor" opacity="0.9"/>
                </svg>
                QuadNine
            </a>
            <span>·</span>
            <span>&copy; {{ "now"|date("Y") }}</span>
        </div>
    </div>
</footer>
