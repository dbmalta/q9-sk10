{% extends "layouts/base.html.twig" %}

{% block layout %}{% endblock %}

{% block body_wrapper %}
{# --- Topbar --- #}
<nav class="topbar navbar navbar-expand fixed-top border-bottom bg-body">
    <div class="container-fluid">
        {# Left: hamburger + logo #}
        <div class="d-flex align-items-center">
            <button class="btn btn-link text-body p-1 me-2 d-lg-none" type="button"
                    data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas"
                    aria-label="Toggle navigation">
                <i class="bi bi-list fs-4"></i>
            </button>
            <button class="btn btn-link text-body p-1 me-2 d-none d-lg-inline-block sidebar-toggle"
                    type="button" aria-label="Toggle sidebar"
                    x-data x-on:click="$store.sidebar.toggle()">
                <i class="bi bi-list fs-4"></i>
            </button>
            <a href="/admin/dashboard" class="navbar-brand mb-0 fw-semibold text-body text-decoration-none">
                {{ app_name|default('ScoutKeeper') }}
            </a>
        </div>

        {# Centre: search (desktop only) #}
        {# No <form> wrapper: avoids Enter-key race with form submission. #}
        {# input[type=search] natively fires the 'search' event on Enter. #}
        <div class="d-none d-md-flex flex-grow-1 justify-content-center position-relative topbar-search" style="max-width: 400px; margin: 0 auto;">
            <div class="input-group input-group-sm w-100">
                <span class="input-group-text bg-body border-end-0"><i class="bi bi-search"></i></span>
                <input type="search" name="search" class="form-control border-start-0"
                       placeholder="{{ t('common.search') }}..."
                       autocomplete="off"
                       hx-get="/search"
                       hx-trigger="keyup changed delay:300ms, search, keyup[key=='Enter']"
                       hx-target="#search-results"
                       hx-sync="this:replace">
            </div>
            <div id="search-results" class="global-search-results"></div>
        </div>

        {# Right: utilities #}
        <div class="d-flex align-items-center gap-1">
            {# Language switcher #}
            <div class="dropdown">
                <button class="btn btn-link text-body p-1" data-bs-toggle="dropdown" aria-expanded="false"
                        title="{{ t('common.language')|default('Language') }}">
                    <i class="bi bi-globe2"></i>
                    <span class="d-none d-sm-inline ms-1 small">{{ app_lang|upper }}</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    {% for lang in available_languages() %}
                    <li>
                        <form method="POST" action="/language/switch" class="m-0">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <input type="hidden" name="code" value="{{ lang.code }}">
                            <input type="hidden" name="redirect_to" value="{{ current_uri }}">
                            <button type="submit" class="dropdown-item d-flex align-items-center {{ lang.code == app_lang ? 'active' : '' }}">
                                <span class="text-uppercase small me-2 text-body-secondary" style="min-width: 2rem;">{{ lang.code }}</span>
                                <span>{{ lang.native_name }}</span>
                                {% if lang.code == app_lang %}
                                <i class="bi bi-check2 ms-auto"></i>
                                {% endif %}
                            </button>
                        </form>
                    </li>
                    {% endfor %}
                </ul>
            </div>

            {# Notifications bell #}
            <button class="btn btn-link text-body p-1 position-relative" title="Notifications">
                <i class="bi bi-bell"></i>
            </button>

            {# Theme toggle (desktop only) #}
            <button class="btn btn-link text-body p-1 d-none d-lg-inline-block" title="{{ t('theme.toggle') }}"
                    x-data x-on:click="$store.theme.toggle()">
                <i class="bi" x-data :class="$store.theme.icon"></i>
            </button>

            {# User menu #}
            <div class="dropdown">
                <button class="btn btn-link text-body p-1" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-person-circle"></i>
                    <span class="d-none d-sm-inline ms-1 small">{{ user.email|default('') }}</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="/account"><i class="bi bi-person me-2"></i>{{ t('user.menu.profile') }}</a></li>
                    <li><hr class="dropdown-divider"></li>
                    {# Theme toggle for mobile (inside user menu) #}
                    <li class="d-lg-none">
                        <button class="dropdown-item" x-data x-on:click="$store.theme.toggle()">
                            <i class="bi me-2" :class="$store.theme.icon"></i>{{ t('theme.toggle') }}
                        </button>
                    </li>
                    <li class="d-lg-none"><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>{{ t('user.menu.logout') }}</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

{# --- Sidebar (desktop) --- #}
<aside class="sidebar d-none d-lg-block" x-data :class="$store.sidebar.collapsed ? 'sidebar-collapsed' : ''">
    <nav class="sidebar-nav">
        {% for group_id, items in nav_items %}
        <div class="sidebar-group">
            <div class="sidebar-group-label text-uppercase small fw-semibold text-body-secondary px-3 py-2">
                {{ t('nav.group.' ~ group_id) }}
            </div>
            {% for item in items %}
            <a href="{{ item.route }}" class="sidebar-link d-flex align-items-center px-3 py-2 text-decoration-none rounded-2 {{ current_uri starts with item.route ? 'active' : '' }}">
                <i class="bi {{ item.icon }} sidebar-icon"></i>
                <span class="sidebar-label">{{ t(item.label) }}</span>
                {% if item.badge %}
                <span class="badge bg-primary rounded-pill ms-auto">{{ item.badge }}</span>
                {% endif %}
            </a>
            {% endfor %}
        </div>
        {% endfor %}
    </nav>
</aside>

{# --- Sidebar (mobile offcanvas) --- #}
<div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarOffcanvas">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title fw-semibold">{{ app_name|default('ScoutKeeper') }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ t('common.close') }}"></button>
    </div>
    <div class="offcanvas-body p-0">
        {# Search (mobile) — no <form> wrapper, same rationale as desktop. #}
        <div class="p-3 border-bottom">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-body border-end-0"><i class="bi bi-search"></i></span>
                <input type="search" name="search" class="form-control border-start-0"
                       placeholder="{{ t('common.search') }}..."
                       autocomplete="off"
                       hx-get="/search"
                       hx-trigger="keyup changed delay:300ms, search, keyup[key=='Enter']"
                       hx-target="#search-results-mobile"
                       hx-sync="this:replace">
            </div>
            <div id="search-results-mobile" class="mt-2"></div>
        </div>

        <nav class="py-2">
            {% for group_id, items in nav_items %}
            <div class="px-3 py-2">
                <div class="text-uppercase small fw-semibold text-body-secondary mb-1">
                    {{ t('nav.group.' ~ group_id) }}
                </div>
                {% for item in items %}
                <a href="{{ item.route }}" class="d-flex align-items-center px-2 py-2 text-decoration-none rounded-2 {{ current_uri starts with item.route ? 'active' : '' }}"
                   data-bs-dismiss="offcanvas">
                    <i class="bi {{ item.icon }} me-2"></i>
                    <span>{{ t(item.label) }}</span>
                    {% if item.badge %}
                    <span class="badge bg-primary rounded-pill ms-auto">{{ item.badge }}</span>
                    {% endif %}
                </a>
                {% endfor %}
            </div>
            {% endfor %}
        </nav>
    </div>
</div>

{# --- Main content area --- #}
<div class="main-content">
    {# Breadcrumbs #}
    {% if breadcrumbs is not empty %}
    <nav aria-label="breadcrumb" class="px-4 pt-3">
        <ol class="breadcrumb mb-0 small">
            {% for crumb in breadcrumbs %}
            {% if loop.last %}
            <li class="breadcrumb-item active" aria-current="page">{{ crumb.label }}</li>
            {% else %}
            <li class="breadcrumb-item"><a href="{{ crumb.url }}">{{ crumb.label }}</a></li>
            {% endif %}
            {% endfor %}
        </ol>
    </nav>
    {% endif %}

    {# Flash messages #}
    {% set flashes = flash() %}
    {% if flashes is not empty %}
    <div class="px-4 pt-3">
        {% for type, messages in flashes %}
            {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ t('common.close') }}"></button>
            </div>
            {% endfor %}
        {% endfor %}
    </div>
    {% endif %}

    <main id="main-content" class="p-4">
        {% block body %}{% endblock %}
    </main>
</div>

{# Session timeout modal #}
<div class="modal fade" id="sessionTimeoutModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ t('session.timeout.title') }}</h5>
            </div>
            <div class="modal-body">
                <p>{{ t('session.timeout.message') }}</p>
                <a href="/login" class="btn btn-primary w-100">{{ t('session.timeout.login') }}</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
