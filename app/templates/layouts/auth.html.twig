{% extends "layouts/base.html.twig" %}

{% block layout %}{% endblock %}

{% block body_wrapper %}
<div class="d-flex flex-column align-items-center justify-content-center min-vh-100 p-4 bg-body-tertiary">
    {# Language switcher (top-right) #}
    <div class="position-absolute top-0 end-0 p-3">
        <div class="dropdown">
            <button class="btn btn-sm btn-link text-body-secondary" data-bs-toggle="dropdown">
                <i class="bi bi-globe2 me-1"></i>{{ app_lang|upper }}
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                {% for lang in available_languages() %}
                <li>
                    <form method="POST" action="/language/switch" class="m-0">
                        <input type="hidden" name="_lang_csrf" value="{{ csrf_token }}">
                        <input type="hidden" name="lang_code" value="{{ lang.code }}">
                        <input type="hidden" name="redirect_to" value="{{ current_uri }}">
                        <button type="button" onclick="this.closest('form').submit()" class="dropdown-item language-switch-item d-flex align-items-center {{ lang.code == app_lang ? 'active' : '' }}">
                            <span class="text-uppercase small me-2 text-body-secondary" style="min-width: 2rem;">{{ lang.code }}</span>
                            <span>{{ lang.native_name }}</span>
                            {% if lang.code == app_lang %}
                            <i class="bi bi-check2 ms-auto"></i>
                            {% endif %}
                        </button>
                    </form>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>

    {# Logo + org name #}
    <div class="text-center mb-4">
        <h1 class="h4 fw-semibold mb-1">{{ app_name|default('ScoutKeeper') }}</h1>
    </div>

    {# Auth card #}
    <div class="card shadow-sm border-0" style="max-width: 420px; width: 100%;">
        <div class="card-body p-4">
            {# Flash messages inside the card #}
            {% set flashes = flash() %}
            {% if flashes is not empty %}
                {% for type, messages in flashes %}
                    {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-sm py-2 px-3 small" role="alert">
                        {{ message }}
                    </div>
                    {% endfor %}
                {% endfor %}
            {% endif %}

            <main id="main-content">
                {% block body %}{% endblock %}
            </main>
        </div>
    </div>

    {# Footer #}
    <div class="mt-4 text-center text-body-secondary small">
        <span class="fw-semibold">{{ app_name|default('ScoutKeeper') }}</span> v{{ app_version|default('0.0.0') }}
        &nbsp;·&nbsp;
        {{ t('footer.built_by') }}
        <a href="https://quadnine.com" class="text-body text-decoration-none fw-medium"
           target="_blank" rel="noopener noreferrer">QuadNine</a>
        &nbsp;·&nbsp; &copy; {{ "now"|date("Y") }}
    </div>
</div>
{% endblock %}
