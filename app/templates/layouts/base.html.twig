<!DOCTYPE html>
<html lang="{{ app_lang|default('en') }}" data-bs-theme="{{ theme|default('light') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>{% block title %}{{ app_name|default('ScoutKeeper') }}{% endblock %} — {{ app_name|default('ScoutKeeper') }}</title>

    {# Apply theme before any CSS/content to prevent FOUC (flash of light content in dark mode) #}
    <script>
        (function () {
            try {
                var stored = localStorage.getItem('sk-theme');
                var theme = stored || (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                document.documentElement.setAttribute('data-bs-theme', theme);
                document.documentElement.style.colorScheme = theme;
            } catch (e) {}
        })();
    </script>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="{{ asset('vendor/bootstrap/css/bootstrap.min.css') }}">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="{{ asset('vendor/bootstrap-icons/bootstrap-icons.min.css') }}">
    <!-- ScoutKeeper Design System -->
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">

    {% block head %}{% endblock %}
</head>
<body>
    <!-- Skip to content (accessibility) -->
    <a href="#main-content" class="visually-hidden-focusable position-absolute top-0 start-0 p-2 bg-primary text-white">
        Skip to content
    </a>

    {% block layout %}{% endblock %}

    {% block body_wrapper %}
    <main id="main-content">
        {# Flash messages #}
        {% set flashes = flash() %}
        {% if flashes is not empty %}
        <div class="container-fluid px-4 pt-3">
            {% for type, messages in flashes %}
                {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ t('common.close') }}"></button>
                </div>
                {% endfor %}
            {% endfor %}
        </div>
        {% endif %}

        {% block body %}{% endblock %}
    </main>
    {% endblock %}

    <!-- Bootstrap JS -->
    <script src="{{ asset('vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    <!-- Alpine.js -->
    <script defer src="{{ asset('vendor/alpine/alpine.min.js') }}"></script>
    <!-- HTMX -->
    <script src="{{ asset('vendor/htmx/htmx.min.js') }}"></script>
    <!-- ScoutKeeper JS -->
    <script src="{{ asset('js/app.js') }}"></script>
    <script src="{{ asset('js/wysiwyg.js') }}"></script>

    {# HTMX CSRF token header for all requests #}
    <script>
        document.body.addEventListener('htmx:configRequest', function(event) {
            event.detail.headers['X-CSRF-Token'] = '{{ csrf_token() }}';
        });
    </script>

    {% block scripts %}{% endblock %}

    {# Pending-acknowledgements auto-popup modal — rendered outside the fixed
       topbar to avoid z-index/stacking issues. #}
    {% include "components/_pending_ack_modal.html.twig" ignore missing %}
</body>
</html>
